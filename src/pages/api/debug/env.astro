---
// Debug endpoint to verify locals.runtime.env is accessible
export const prerender = false;
---
{
  // @ts-ignore - access Astro global
  const env = Astro.locals?.runtime?.env;
  const hasEnv = env !== undefined && env !== null;
  const envKeys = hasEnv ? Object.keys(env).filter(k => k.includes('KEYSTATIC') || k.includes('GITHUB') || k.includes('SESSION') || k.includes('ASSETS')) : [];
  
  return new Response(JSON.stringify({
    hasRuntime: Astro.locals?.runtime !== undefined,
    hasEnv,
    envType: hasEnv ? typeof env : 'N/A',
    envKeys,
  }), {
    headers: { 'Content-Type': 'application/json' }
  });
}
