---
import PageLayout from '~/layouts/PageLayout.astro';
---

<PageLayout
  metadata={{
    title: 'Brochures & Datasheets — OWON Resources',
    description: 'Download product brochures, datasheets, and technical documentation.',
  }}
>
  <section class="py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl font-bold mb-2 text-default dark:text-slate-100">Brochures & Datasheets</h1>
      <p class="text-lg text-muted dark:text-slate-400 mb-8 max-w-2xl">
        Download product brochures, solution PDFs, and technical datasheets. Enter your work email to unlock downloads.
      </p>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          ['Corporate Brochure', 'Smart Hotel Solution', 'Smart Meter Datasheet', 'User Manual'].map((item) => (
            <div class="p-6 rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-center">
              <div class="text-4xl mb-3">📄</div>
              <h3 class="font-semibold text-sm text-default dark:text-slate-200 mb-1">{item}</h3>
              <p class="text-xs text-muted dark:text-slate-500 mb-4">PDF • 2.4 MB</p>
              <button
                type="button"
                onclick="window.__openLeadModal?.({ scenario: 'pdf', pdfUrl: '#' })"
                class="px-4 py-2 rounded-lg text-xs font-medium bg-primary text-primary-foreground hover:opacity-90 transition-opacity"
              >
                Download
              </button>
            </div>
          ))
        }
      </div>

      <div class="mt-8 text-center text-sm text-muted dark:text-slate-500">
        More resources coming soon. <a href="/contact-sales" class="text-primary hover:underline">Contact sales</a> for custom
        documentation.
      </div>
    </div>
  </section>
</PageLayout>
