---
import PageLayout from '~/layouts/PageLayout.astro';

const faqItems = [
  {
    category: 'Installation',
    items: [
      {
        q: 'How do I install the smart meter?',
        a: 'DIN rail mount. Follow the wiring diagram included in the box. Detailed guides available in the user manual.',
      },
      { q: 'Do I need an electrician?', a: 'Yes — installation requires a certified electrician for mains wiring.' },
    ],
  },
  {
    category: 'Connectivity',
    items: [
      {
        q: 'Does it work without internet?',
        a: 'Yes — local ZigBee and Modbus communication works without internet. Cloud features require internet.',
      },
      { q: 'Which protocols are supported?', a: 'ZigBee 3.0, Wi-Fi 802.11 b/g/n, Modbus RTU/TCP, MQTT, and TCP/IP.' },
    ],
  },
  {
    category: 'API & Integration',
    items: [
      { q: 'Is there a public API?', a: 'Yes — MQTT and REST API available. Documentation at /developers/api.' },
      {
        q: 'Can I integrate with Home Assistant?',
        a: 'Yes — OWON devices support local API for Home Assistant integration.',
      },
    ],
  },
  {
    category: 'Billing & Order',
    items: [
      { q: 'How do I get pricing?', a: 'Use the Get Base Price button on any product, or contact sales.' },
      {
        q: 'Do you offer OEM/ODM?',
        a: 'Yes — contact sales for customization options, minimum order quantities, and lead times.',
      },
    ],
  },
];
const allQuestions = faqItems.flatMap((cat) => cat.items);

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: allQuestions.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
---

<PageLayout
  metadata={{
    title: 'FAQ — OWON Resources',
    description: 'Frequently asked questions about OWON products, installation, API, and ordering.',
  }}
>
  <section class="py-12">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl font-bold mb-2 text-default dark:text-slate-100">FAQ</h1>
      <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
      <p class="text-lg text-muted dark:text-slate-400 mb-8">
        Frequently asked questions about OWON products and services.
      </p>

      <input
        type="text"
        id="faqSearch"
        placeholder="Search questions..."
        class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-slate-700 bg-white dark:bg-slate-800 text-default dark:text-slate-200 mb-8 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-shadow"
      />

      <div id="faqList" class="space-y-6">
        {
          faqItems.map((cat) => (
            <div>
              <h2 class="text-lg font-semibold mb-3 text-default dark:text-slate-200">{cat.category}</h2>
              <div class="space-y-2">
                {cat.items.map((item) => (
                  <details class="faq-item group rounded-lg border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800">
                    <summary class="px-4 py-3 cursor-pointer text-sm font-medium text-default dark:text-slate-200 hover:text-primary transition-colors select-none">
                      {item.q}
                    </summary>
                    <p class="px-4 pb-4 text-sm text-muted dark:text-slate-400 leading-relaxed">{item.a}</p>
                  </details>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</PageLayout>

<script is:inline>
  document.getElementById('faqSearch')?.addEventListener('input', function () {
    const query = this.value.toLowerCase();
    document.querySelectorAll('.faq-item').forEach(function (item) {
      const text = (item.textContent || '').toLowerCase();
      item.style.display = !query || text.indexOf(query) !== -1 ? '' : 'none';
    });
  });
</script>
