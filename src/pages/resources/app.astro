---
import PageLayout from '~/layouts/PageLayout.astro';
---

<PageLayout
  metadata={{
    title: 'App Downloads — OWON Resources',
    description:
      'Download OWON mobile apps — MQTT API Debugger, Energy Dashboard, and device configuration tools for iOS and Android.',
  }}
>
  <section class="py-8 lg:py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="mb-4 text-sm text-muted dark:text-slate-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span class="mx-2">/</span>
        <span class="text-default dark:text-slate-200">App Downloads</span>
      </nav>

      <!-- Dimension Tabs -->
      <div class="flex gap-1 p-1 bg-gray-100 dark:bg-slate-800 rounded-xl mb-8 w-fit">
        <a
          href="/resources/brochures"
          class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-200 text-gray-600 dark:text-slate-400 hover:bg-white/60 dark:hover:bg-slate-700/60"
          >📄 Documentation</a
        >
        <a
          href="/resources/videos"
          class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-200 text-gray-600 dark:text-slate-400 hover:bg-white/60 dark:hover:bg-slate-700/60"
          >🎬 Videos</a
        >
        <a
          href="/resources/app"
          class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-200 bg-white dark:bg-slate-700 text-default dark:text-slate-200 shadow-sm"
          >📱 App Downloads</a
        >
      </div>

      <!-- API Debugger -->
      <section class="mb-12">
        <h2 class="text-xl font-bold mb-6 text-default dark:text-slate-200">🔧 OWON API Debugger</h2>
        <p class="text-sm text-muted dark:text-slate-400 mb-6">
          Inspect MQTT traffic, test API endpoints, and simulate device data — all from your mobile device.
        </p>
        <div class="grid gap-4 sm:grid-cols-2">
          <div
            class="p-5 rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 flex items-center gap-4"
          >
            <span class="text-3xl">🍎</span>
            <div>
              <h3 class="font-semibold text-default dark:text-slate-200 text-sm">OWON API Debugger — iOS</h3>
              <p class="text-xs text-muted dark:text-slate-400 mb-2">
                MQTT monitor, API request builder, device simulator
              </p>
              <span class="inline-flex items-center gap-1 text-xs text-muted dark:text-slate-500 font-medium"
                >Coming soon on App Store</span
              >
            </div>
          </div>
          <div
            class="p-5 rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 flex items-center gap-4"
          >
            <span class="text-3xl">🤖</span>
            <div>
              <h3 class="font-semibold text-default dark:text-slate-200 text-sm">OWON API Debugger — Android</h3>
              <p class="text-xs text-muted dark:text-slate-400 mb-2">
                MQTT monitor, API request builder, device simulator
              </p>
              <span class="inline-flex items-center gap-1 text-xs text-muted dark:text-slate-500 font-medium"
                >Coming soon on Google Play</span
              >
            </div>
          </div>
        </div>
      </section>

      <!-- Energy Dashboard -->
      <section class="mb-12">
        <h2 class="text-xl font-bold mb-6 text-default dark:text-slate-200">📊 OWON Energy Dashboard</h2>
        <p class="text-sm text-muted dark:text-slate-400 mb-6">
          Real-time energy monitoring dashboard — track consumption, view trends, and manage multiple sites.
        </p>
        <div class="grid gap-4 sm:grid-cols-2">
          <div
            class="p-5 rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 flex items-center gap-4"
          >
            <span class="text-3xl">🍎</span>
            <div>
              <h3 class="font-semibold text-default dark:text-slate-200 text-sm">Energy Dashboard — iOS</h3>
              <p class="text-xs text-muted dark:text-slate-400 mb-2">Web-based dashboard, optimized for mobile</p>
              <span class="inline-flex items-center gap-1 text-xs text-muted dark:text-slate-500 font-medium"
                >Coming soon on App Store</span
              >
            </div>
          </div>
          <div
            class="p-5 rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 flex items-center gap-4"
          >
            <span class="text-3xl">🤖</span>
            <div>
              <h3 class="font-semibold text-default dark:text-slate-200 text-sm">Energy Dashboard — Android</h3>
              <p class="text-xs text-muted dark:text-slate-400 mb-2">Web-based dashboard, optimized for mobile</p>
              <span class="inline-flex items-center gap-1 text-xs text-muted dark:text-slate-500 font-medium"
                >Coming soon on Google Play</span
              >
            </div>
          </div>
        </div>
      </section>

      <!-- Device Config Tool -->
      <section class="mb-12">
        <h2 class="text-xl font-bold mb-6 text-default dark:text-slate-200">⚙️ OWON Device Config</h2>
        <p class="text-sm text-muted dark:text-slate-400 mb-6">
          On-site device configuration tool — scan ZigBee networks, configure WiFi credentials, and update firmware.
        </p>
        <div class="grid gap-4 sm:grid-cols-2">
          <div
            class="p-5 rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 flex items-center gap-4"
          >
            <span class="text-3xl">🤖</span>
            <div>
              <h3 class="font-semibold text-default dark:text-slate-200 text-sm">Device Config Tool — Android</h3>
              <p class="text-xs text-muted dark:text-slate-400 mb-2">ZigBee scanner, WiFi config, firmware update</p>
              <span class="inline-flex items-center gap-1 text-xs text-muted dark:text-slate-500 font-medium"
                >Coming soon on Google Play</span
              >
            </div>
          </div>
        </div>
      </section>
    </div>
  </section>
</PageLayout>
