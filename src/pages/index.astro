---
export const prerender = false;

import Layout from '~/layouts/PageLayout.astro';

import CallToAction from '~/components/widgets/CallToAction.astro';
import ProductGrid from '~/components/products/ProductGrid.astro';

import { getPermalink } from '~/utils/permalinks';
import { products as rawProducts } from '~/data/products';
import { SITE } from 'astrowind:config';
import { getCollection } from 'astro:content';

const metadata = {
  title: 'Smart IoT Devices for Your Industry — OWON Technology',
  ignoreTitleTemplate: true,
};

const productsUrl = getPermalink('/products');
const contactUrl = getPermalink('/contact-sales');
const developersUrl = getPermalink('/developers');
const solutionsUrl = getPermalink('/solutions');
const blogUrl = getPermalink('/blog');
const whatsappNumber = SITE.contact?.whatsapp || '8618650139895';

// All products from data
const allProducts = rawProducts.map((p) => ({
  ...p.data,
  id: p.slug,
  slug: p.slug,
  collection: 'products' as const,
  data: p.data,
}));

// Ecosystem groups
const ecosystemGroups = [
  {
    id: 'tuya',
    label: 'Tuya',
    desc: 'Tuya-enabled smart devices with ZigBee/WiFi',
    icon: '🔵',
    filter: (p) => p.techSolution === 'tuya' || (p.ecosystem || []).includes('tuya'),
  },
  {
    id: 'ha',
    label: 'Home Assistant',
    desc: 'Zigbee2MQTT & native HA integration',
    icon: '🏠',
    filter: (p) => (p.ecosystem || []).some((e) => e.includes('zigbee') || e.includes('ha')),
  },
  {
    id: 'mqtt',
    label: 'MQTT Open',
    desc: 'Standard MQTT 3.1.1/5.0 protocol devices',
    icon: '📡',
    filter: (p) => p.techSolution === 'mqtt' || (p.communication || []).includes('mqtt'),
  },
  {
    id: 'http',
    label: 'HTTP API',
    desc: 'REST API & webhook-enabled products',
    icon: '🔌',
    filter: (p) => (p.ecosystem || []).includes('local-api') || (p.communication || []).includes('tcpip'),
  },
  {
    id: 'modbus',
    label: 'Modbus',
    desc: 'RS-485 Modbus RTU industrial devices',
    icon: '⚙️',
    filter: (p) => (p.communication || []).includes('modbus'),
  },
];

// Protocol groups
const protocolGroups = [
  { id: 'wifi', label: 'WiFi', icon: '📶', filter: (p) => (p.communication || []).includes('wifi') },
  { id: '4g', label: '4G / LTE', icon: '📱', filter: (p) => (p.communication || []).includes('4g') },
  { id: 'zigbee', label: 'ZigBee', icon: '🔷', filter: (p) => (p.communication || []).includes('zigbee') },
  {
    id: 'rf',
    label: 'RF 868/433',
    icon: '📻',
    filter: (p) => (p.communication || []).some((c) => c.includes('rf') || c.includes('868') || c.includes('433')),
  },
  { id: 'ethernet', label: 'Ethernet', icon: '🔗', filter: (p) => (p.communication || []).includes('tcpip') },
  { id: 'rs485', label: 'RS-485', icon: '🔧', filter: (p) => (p.communication || []).includes('modbus') },
];

const industries = [
  { icon: '🏨', title: 'Smart Hotels', desc: 'Guest room automation & energy management' },
  { icon: '⚡', title: 'Energy Management', desc: 'Sub-metering, monitoring & analytics' },
  { icon: '🏢', title: 'Smart Building', desc: 'HVAC, lighting & access control' },
  { icon: '🏥', title: 'Senior Care', desc: 'Non-contact monitoring & safety alerts' },
  { icon: '🏭', title: 'Industrial IoT', desc: 'Factory monitoring & predictive maintenance' },
];

// Latest blog posts for homepage
const blogPosts = await getCollection('post');
const latestPosts = blogPosts
  .filter((p) => !p.data.draft)
  .sort((a, b) => {
    const dateA = a.data.publishDate ? new Date(a.data.publishDate).getTime() : 0;
    const dateB = b.data.publishDate ? new Date(b.data.publishDate).getTime() : 0;
    return dateB - dateA;
  })
  .slice(0, 3);

const formatDate = (date: Date | undefined): string => {
  if (!date) return '';
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
};
---

<Layout metadata={metadata}>
  <!-- ===== 1. Hero ===== -->
  <section class="relative overflow-hidden bg-white dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="text-center lg:text-left">
          <h1
            class="text-5xl md:text-6xl font-bold leading-tighter tracking-tighter mb-4 font-heading dark:text-gray-200"
          >
            Smart IoT Devices for Your Industry
          </h1>
          <p class="text-xl text-muted mb-6 dark:text-slate-300 max-w-2xl lg:mx-0">
            Smart meters, thermostats, senior care, hotel control & IoT platforms — trusted by B2B customers worldwide.
          </p>
          <div class="flex flex-wrap gap-4 justify-center lg:justify-start">
            <a
              href={productsUrl}
              class="inline-flex items-center gap-2 rounded-full bg-primary hover:bg-primary/90 text-white font-medium px-8 py-3 transition-colors"
            >
              View Products
            </a>
            <a
              href={contactUrl}
              class="inline-flex items-center gap-2 rounded-full bg-gray-100 dark:bg-slate-800 hover:bg-gray-200 dark:hover:bg-slate-700 text-default dark:text-slate-200 font-medium px-8 py-3 transition-colors"
            >
              Contact Sales
            </a>
          </div>
          <!-- Trust badges -->
          <div class="flex flex-wrap justify-center lg:justify-start gap-3 mt-6">
            <span
              class="inline-flex items-center gap-1.5 rounded-full bg-green-100 dark:bg-green-900/40 px-3 py-1.5 text-sm font-medium text-green-700 dark:text-green-300"
            >
              <span class="text-green-600 dark:text-green-400 text-xs font-bold">&#10003;</span> CE Certified
            </span>
            <span
              class="inline-flex items-center gap-1.5 rounded-full bg-blue-100 dark:bg-blue-900/40 px-3 py-1.5 text-sm font-medium text-blue-700 dark:text-blue-300"
            >
              <span class="text-blue-600 dark:text-blue-400 text-xs font-bold">&#10003;</span> FCC Certified
            </span>
            <span
              class="inline-flex items-center gap-1.5 rounded-full bg-purple-100 dark:bg-purple-900/40 px-3 py-1.5 text-sm font-medium text-purple-700 dark:text-purple-300"
            >
              <span class="text-purple-600 dark:text-purple-400 text-xs font-bold">&#10003;</span> RoHS Compliant
            </span>
          </div>
          <!-- Key stats -->
          <div class="mt-8 grid grid-cols-3 gap-4 max-w-xl lg:mx-0">
            <div class="text-center lg:text-left">
              <div class="text-3xl font-bold text-primary dark:text-blue-300">1M+</div>
              <div class="text-sm text-muted dark:text-slate-400 mt-1">Devices Deployed</div>
            </div>
            <div class="text-center lg:text-left">
              <div class="text-3xl font-bold text-primary dark:text-blue-300">50+</div>
              <div class="text-sm text-muted dark:text-slate-400 mt-1">Countries</div>
            </div>
            <div class="text-center lg:text-left">
              <div class="text-3xl font-bold text-primary dark:text-blue-300">15+</div>
              <div class="text-sm text-muted dark:text-slate-400 mt-1">Years R&amp;D</div>
            </div>
          </div>
        </div>
        <div
          class="relative rounded-2xl overflow-hidden bg-gray-100 dark:bg-slate-800 aspect-[4/3] max-w-md mx-auto lg:mx-0"
        >
          <div class="absolute inset-0 flex items-center justify-center text-6xl text-gray-300 dark:text-slate-600">
            🏭
          </div>
          <div class="absolute bottom-3 left-3 text-xs text-gray-400">Smart Factory — Xiamen, China</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 2. Solutions by Industry ===== -->
  <section class="py-16 lg:py-20 bg-gray-50 dark:bg-slate-800/50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between mb-10 gap-4">
        <div>
          <h2 class="text-3xl font-bold text-default dark:text-slate-100">Solutions by Industry</h2>
          <p class="mt-2 text-muted dark:text-slate-400 max-w-xl">
            Tailored IoT solutions for every sector — from concept to deployment.
          </p>
        </div>
        <a
          href={solutionsUrl}
          class="inline-flex items-center gap-1 text-primary hover:underline font-medium text-sm whitespace-nowrap"
        >
          View Solutions &rarr;
        </a>
      </div>
      <div class="grid gap-6 grid-cols-2 lg:grid-cols-5">
        {
          industries.map((item) => (
            <a
              href={solutionsUrl}
              class="group flex flex-col rounded-xl bg-white dark:bg-slate-800 shadow-md hover:shadow-lg border border-gray-200 dark:border-slate-700 transition-all hover:-translate-y-0.5 overflow-hidden"
            >
              <div class="aspect-video bg-gray-100 dark:bg-slate-700 flex items-center justify-center text-4xl">
                {item.icon}
              </div>
              <div class="p-5">
                <h3 class="text-base font-semibold text-default dark:text-slate-200 group-hover:text-primary transition-colors mb-2">
                  {item.title}
                </h3>
                <p class="text-sm text-muted dark:text-slate-400 leading-relaxed">{item.desc}</p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== 3. Products by Ecosystem & Protocol ===== -->
  <section class="py-16 lg:py-20 bg-white dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8" id="productsSection">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-default dark:text-slate-100">Products by Ecosystem &amp; Protocol</h2>
        <p class="mt-3 text-muted dark:text-slate-400 max-w-2xl mx-auto">
          Browse our product catalogue by ecosystem platform or communication protocol.
        </p>
      </div>

      <!-- Dimension tabs -->
      <div class="flex gap-1 p-1 bg-gray-100 dark:bg-slate-800 rounded-xl w-fit mx-auto mb-6">
        <button
          class="dim-btn inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-semibold cursor-pointer transition-all duration-200 bg-white dark:bg-slate-700 text-default dark:text-slate-200 shadow-sm active"
          data-dim="ecosystem"
        >
          By Ecosystem
        </button>
        <button
          class="dim-btn inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-semibold cursor-pointer transition-all duration-200 text-gray-600 dark:text-slate-400 hover:bg-white/60 dark:hover:bg-slate-700/60"
          data-dim="protocol"
        >
          By Protocol
        </button>
      </div>

      <!-- Group tabs -->
      <div id="groupTabs" class="flex flex-wrap gap-2 justify-center mb-8">
        {
          ecosystemGroups.map((g, i) => (
            <button
              class="group-tab inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm font-medium cursor-pointer transition-all duration-150 border"
              data-dim="ecosystem"
              data-group={g.id}
              class:list={[
                i === 0
                  ? 'bg-primary text-white border-primary'
                  : 'bg-white dark:bg-slate-800 text-gray-600 dark:text-slate-400 border-gray-300 dark:border-slate-600 hover:border-primary',
              ]}
            >
              {g.icon} {g.label}
            </button>
          ))
        }
        {
          protocolGroups.map((g, i) => (
            <button
              class="group-tab hidden inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm font-medium cursor-pointer transition-all duration-150 border"
              data-dim="protocol"
              data-group={g.id}
              class:list={[
                i === 0
                  ? 'bg-primary text-white border-primary'
                  : 'bg-white dark:bg-slate-800 text-gray-600 dark:text-slate-400 border-gray-300 dark:border-slate-600 hover:border-primary',
              ]}
            >
              {g.icon} {g.label}
            </button>
          ))
        }
      </div>

      <!-- Product grids -->
      <div id="productGrids">
        {
          ecosystemGroups.map((g, i) => (
            <div
              id={`grid-${g.id}`}
              class:list={['product-grid', i === 0 ? '' : 'hidden']}
              data-dim="ecosystem"
              data-group={g.id}
            >
              <p class="text-sm text-muted dark:text-slate-400 mb-4 text-center">{g.desc}</p>
              <ProductGrid products={allProducts.filter(g.filter).slice(0, 4)} baseUrl="/products" />
            </div>
          ))
        }
        {
          protocolGroups.map((g) => (
            <div id={`grid-${g.id}`} class="product-grid hidden" data-dim="protocol" data-group={g.id}>
              <ProductGrid products={allProducts.filter(g.filter).slice(0, 4)} baseUrl="/products" />
            </div>
          ))
        }
      </div>

      <div class="text-center mt-8">
        <a href={productsUrl} class="inline-flex items-center gap-1 text-primary hover:underline font-medium">
          View All Products &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- ===== 4. Company & Factory ===== -->
  <section class="py-16 lg:py-20 bg-gray-50 dark:bg-slate-800/50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-3 gap-10 md:divide-x md:divide-gray-200 dark:md:divide-slate-700">
        <!-- Company -->
        <div class="md:pr-10">
          <h2 class="text-2xl font-bold text-default dark:text-slate-100 mb-4">Company</h2>
          <p class="text-sm text-muted dark:text-slate-400 leading-relaxed mb-6">
            XIAMEN OWON TECHNOLOGY CO.,LTD is a leading IoT device manufacturer with 15+ years of R&D expertise. We
            design, manufacture, and deliver smart energy meters, thermostats, and IoT solutions to B2B customers across
            50+ countries.
          </p>
          <div class="grid grid-cols-2 gap-4">
            <div class="text-center">
              <div class="text-2xl font-bold text-primary">1M+</div>
              <div class="text-xs text-muted dark:text-slate-400">Devices</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-primary">50+</div>
              <div class="text-xs text-muted dark:text-slate-400">Countries</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-primary">15+</div>
              <div class="text-xs text-muted dark:text-slate-400">Years R&amp;D</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-primary">200+</div>
              <div class="text-xs text-muted dark:text-slate-400">Employees</div>
            </div>
          </div>
        </div>
        <!-- Factory -->
        <div class="md:px-10">
          <h2 class="text-2xl font-bold text-default dark:text-slate-100 mb-4">Factory</h2>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <span class="text-green-500 shrink-0 mt-0.5 text-lg font-bold">&#10003;</span>
              <span class="text-sm text-default dark:text-slate-200"
                >20,000m&sup2; manufacturing facility in Xiamen, China</span
              >
            </li>
            <li class="flex items-start gap-3">
              <span class="text-green-500 shrink-0 mt-0.5 text-lg font-bold">&#10003;</span>
              <span class="text-sm text-default dark:text-slate-200">ISO 9001 certified quality management</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-green-500 shrink-0 mt-0.5 text-lg font-bold">&#10003;</span>
              <span class="text-sm text-default dark:text-slate-200">In-house SMT production lines</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-green-500 shrink-0 mt-0.5 text-lg font-bold">&#10003;</span>
              <span class="text-sm text-default dark:text-slate-200">Dedicated reliability testing lab</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-green-500 shrink-0 mt-0.5 text-lg font-bold">&#10003;</span>
              <span class="text-sm text-default dark:text-slate-200">24/7 production capability</span>
            </li>
          </ul>
        </div>
        <!-- Certifications -->
        <div class="md:pl-10">
          <h2 class="text-2xl font-bold text-default dark:text-slate-100 mb-4">Certifications</h2>
          <div class="flex flex-wrap gap-2">
            <span
              class="inline-flex items-center gap-1.5 rounded-full bg-green-100 dark:bg-green-900/40 px-3 py-1.5 text-xs font-medium text-green-700 dark:text-green-300"
            >
              <span class="text-green-600 dark:text-green-400 text-xs font-bold">&#10003;</span> CE
            </span>
            <span
              class="inline-flex items-center gap-1.5 rounded-full bg-blue-100 dark:bg-blue-900/40 px-3 py-1.5 text-xs font-medium text-blue-700 dark:text-blue-300"
            >
              <span class="text-blue-600 dark:text-blue-400 text-xs font-bold">&#10003;</span> FCC
            </span>
            <span
              class="inline-flex items-center gap-1.5 rounded-full bg-purple-100 dark:bg-purple-900/40 px-3 py-1.5 text-xs font-medium text-purple-700 dark:text-purple-300"
            >
              <span class="text-purple-600 dark:text-purple-400 text-xs font-bold">&#10003;</span> RoHS
            </span>
            <span
              class="inline-flex items-center gap-1.5 rounded-full bg-amber-100 dark:bg-amber-900/40 px-3 py-1.5 text-xs font-medium text-amber-700 dark:text-amber-300"
            >
              <span class="text-amber-600 dark:text-amber-400 text-xs font-bold">&#10003;</span> UKCA
            </span>
            <span
              class="inline-flex items-center gap-1.5 rounded-full bg-cyan-100 dark:bg-cyan-900/40 px-3 py-1.5 text-xs font-medium text-cyan-700 dark:text-cyan-300"
            >
              <span class="text-cyan-600 dark:text-cyan-400 text-xs font-bold">&#10003;</span> RED
            </span>
            <span
              class="inline-flex items-center gap-1.5 rounded-full bg-green-100 dark:bg-green-900/40 px-3 py-1.5 text-xs font-medium text-green-700 dark:text-green-300"
            >
              <span class="text-green-600 dark:text-green-400 text-xs font-bold">&#10003;</span> ISO 9001
            </span>
            <span
              class="inline-flex items-center gap-1.5 rounded-full bg-blue-100 dark:bg-blue-900/40 px-3 py-1.5 text-xs font-medium text-blue-700 dark:text-blue-300"
            >
              <span class="text-blue-600 dark:text-blue-400 text-xs font-bold">&#10003;</span> ISO 14001
            </span>
            <span
              class="inline-flex items-center gap-1.5 rounded-full bg-purple-100 dark:bg-purple-900/40 px-3 py-1.5 text-xs font-medium text-purple-700 dark:text-purple-300"
            >
              <span class="text-purple-600 dark:text-purple-400 text-xs font-bold">&#10003;</span> ISO 45001
            </span>
            <span
              class="inline-flex items-center gap-1.5 rounded-full bg-rose-100 dark:bg-rose-900/40 px-3 py-1.5 text-xs font-medium text-rose-700 dark:text-rose-300"
            >
              <span class="text-rose-600 dark:text-rose-400 text-xs font-bold">&#10003;</span> BSCI
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 5. Factory Video ===== -->
  <section class="py-16 lg:py-20 bg-white dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-default dark:text-slate-100">See Our Factory</h2>
      <p class="mt-3 text-muted dark:text-slate-400 max-w-2xl mx-auto mb-10">
        Take a virtual tour of our 20,000m&sup2; manufacturing facility in Xiamen, China.
      </p>
      <div
        class="max-w-3xl mx-auto rounded-2xl bg-slate-800 dark:bg-slate-700 aspect-video flex items-center justify-center cursor-pointer hover:bg-slate-700 dark:hover:bg-slate-600 transition-colors"
      >
        <div class="text-center">
          <div class="w-16 h-16 mx-auto rounded-full bg-white/20 flex items-center justify-center mb-4">
            <svg class="w-7 h-7 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z"></path>
            </svg>
          </div>
          <p class="text-white font-medium text-lg">OWON Factory Tour — Xiamen, China</p>
          <p class="text-slate-400 text-sm mt-1">Click to play video</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 6. Latest from Blog ===== -->
  <section class="py-16 lg:py-20 bg-gray-50 dark:bg-slate-800/50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between mb-10 gap-4">
        <div>
          <h2 class="text-3xl font-bold text-default dark:text-slate-100">Latest from Blog</h2>
          <p class="mt-2 text-muted dark:text-slate-400 max-w-xl">
            Case studies, product updates, and industry insights from the OWON team.
          </p>
        </div>
        <a
          href={blogUrl}
          class="inline-flex items-center gap-1 text-primary hover:underline font-medium text-sm whitespace-nowrap"
        >
          View All Posts &rarr;
        </a>
      </div>
      <div class="grid gap-6 sm:grid-cols-3">
        {
          latestPosts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="group flex flex-col rounded-xl bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 p-6 hover:shadow-md transition-all"
            >
              <time class="text-xs text-muted dark:text-slate-400 mb-2">{formatDate(post.data.publishDate)}</time>
              <h3 class="font-semibold text-default dark:text-slate-200 group-hover:text-primary transition-colors mb-2 line-clamp-2">
                {post.data.title}
              </h3>
              <p class="text-sm text-muted dark:text-slate-400 leading-relaxed line-clamp-2 flex-1">
                {post.data.excerpt}
              </p>
              <span class="inline-flex items-center gap-1 mt-4 text-sm font-medium text-primary group-hover:underline">
                Read more &rarr;
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== 7. Developer CTA ===== -->
  <section class="py-12 lg:py-16 bg-white dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-default dark:text-slate-100">Open API. Full SDKs. Integrate in hours.</h2>
      <p class="mt-3 text-lg text-muted dark:text-slate-400 max-w-2xl mx-auto">
        RESTful APIs, MQTT documentation, SDKs for Python, Node.js, and embedded C — everything your engineering team
        needs.
      </p>
      <div class="mt-8">
        <a
          href={developersUrl}
          class="inline-flex items-center gap-2 rounded-full bg-primary hover:bg-primary/90 text-white font-medium px-8 py-4 transition-colors"
        >
          Explore Developer Docs &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- ===== 8. Contact CTA ===== -->
  <CallToAction
    actions={[
      { variant: 'primary', text: 'Get Product Datasheet & Quote', href: contactUrl, icon: 'tabler:file-description' },
      {
        text: 'Talk to an Engineer',
        href: `https://wa.me/${whatsappNumber}`,
        icon: 'tabler:brand-whatsapp',
      },
    ]}
  >
    <Fragment slot="title">Get Your Product Datasheet &amp; Custom Quote</Fragment>
    <Fragment slot="subtitle">
      Contact us for product catalogues, technical documentation, and customized solution quotes
    </Fragment>
  </CallToAction>
</Layout>

<script>
  (function () {
    const section = document.getElementById('productsSection');
    if (!section) return;

    const dimBtns = section.querySelectorAll('.dim-btn');
    const groupTabs = section.querySelectorAll('.group-tab');
    const grids = section.querySelectorAll('.product-grid');

    function deactivateAll() {
      dimBtns.forEach((b) => {
        b.classList.remove(
          'bg-white',
          'dark:bg-slate-700',
          'text-default',
          'dark:text-slate-200',
          'shadow-sm',
          'active'
        );
        b.classList.add('text-gray-600', 'dark:text-slate-400', 'hover:bg-white/60', 'dark:hover:bg-slate-700/60');
      });
      groupTabs.forEach((t) => {
        t.classList.remove('bg-primary', 'text-white', 'border-primary');
        t.classList.add(
          'bg-white',
          'dark:bg-slate-800',
          'text-gray-600',
          'dark:text-slate-400',
          'border-gray-300',
          'dark:border-slate-600',
          'hover:border-primary'
        );
      });
      grids.forEach((g) => g.classList.add('hidden'));
    }

    function activateDim(dim) {
      deactivateAll(dim);
      dimBtns.forEach((b) => {
        if (b.dataset.dim === dim) {
          b.classList.remove('text-gray-600', 'dark:text-slate-400', 'hover:bg-white/60', 'dark:hover:bg-slate-700/60');
          b.classList.add(
            'bg-white',
            'dark:bg-slate-700',
            'text-default',
            'dark:text-slate-200',
            'shadow-sm',
            'active'
          );
        }
      });
      groupTabs.forEach((t) => {
        if (t.dataset.dim === dim) {
          t.classList.remove('hidden');
        } else {
          t.classList.add('hidden');
        }
      });
      // Activate first group tab in this dimension
      const firstTab = section.querySelector(`.group-tab[data-dim="${dim}"]`);
      if (firstTab) {
        firstTab.classList.remove(
          'bg-white',
          'dark:bg-slate-800',
          'text-gray-600',
          'dark:text-slate-400',
          'border-gray-300',
          'dark:border-slate-600',
          'hover:border-primary'
        );
        firstTab.classList.add('bg-primary', 'text-white', 'border-primary');
        const grid = section.querySelector(`.product-grid[data-dim="${dim}"][data-group="${firstTab.dataset.group}"]`);
        if (grid) grid.classList.remove('hidden');
      }
    }

    function activateGroup(el) {
      const dim = el.dataset.dim;
      const group = el.dataset.group;
      groupTabs.forEach((t) => {
        if (t.dataset.dim === dim) {
          t.classList.remove('bg-primary', 'text-white', 'border-primary');
          t.classList.add(
            'bg-white',
            'dark:bg-slate-800',
            'text-gray-600',
            'dark:text-slate-400',
            'border-gray-300',
            'dark:border-slate-600',
            'hover:border-primary'
          );
        }
      });
      el.classList.remove(
        'bg-white',
        'dark:bg-slate-800',
        'text-gray-600',
        'dark:text-slate-400',
        'border-gray-300',
        'dark:border-slate-600',
        'hover:border-primary'
      );
      el.classList.add('bg-primary', 'text-white', 'border-primary');

      grids.forEach((g) => {
        if (g.dataset.dim === dim && g.dataset.group === group) {
          g.classList.remove('hidden');
        } else if (g.dataset.dim === dim) {
          g.classList.add('hidden');
        }
      });
    }

    dimBtns.forEach((b) => {
      b.addEventListener('click', () => activateDim(b.dataset.dim));
    });

    groupTabs.forEach((t) => {
      t.addEventListener('click', () => activateGroup(t));
    });
  })();
</script>
