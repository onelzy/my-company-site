---
export const prerender = false;

import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'OWON Technology — Smart IoT Device Manufacturer',
  ignoreTitleTemplate: true,
};

const productsUrl = getPermalink('/products');
const contactUrl = getPermalink('/contact-sales');
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <Hero
    actions={[
      { variant: 'primary', text: 'View Products', href: productsUrl, icon: 'tabler:apps' },
      { text: 'Contact Sales', href: contactUrl },
    ]}
  >
    <Fragment slot="title">
      Professional Smart IoT Device Manufacturer
    </Fragment>
    <Fragment slot="subtitle">
      OWON Technology specializes in smart meters, thermostats, senior care, hotel control systems, and IoT platforms — serving B2B customers worldwide.
    </Fragment>
  </Hero>

  <!-- Product Lines -->
  <Features
    id="products"
    title="Core Product Lines"
    subtitle="Five product lines covering smart energy, environmental control, care management, hotel automation, and software platforms"
    items={[
      {
        title: 'Smart Meters',
        description: 'Single / three-phase / multi-circuit / DIN-rail meters with Wi-Fi, ZigBee, Modbus, MQTT support for residential, commercial, and industrial applications.',
        icon: 'tabler:bolt',
      },
      {
        title: 'Smart Thermostats',
        description: '24V AC touchscreen thermostats, ZigBee TRV valves, boiler kits — compatible with major smart home ecosystems for precise temperature control.',
        icon: 'tabler:temperature',
      },
      {
        title: 'Senior Care',
        description: 'Smart sleep monitors, emergency call, safety, tracking, health devices with AiJuan app and nursing station management platform.',
        icon: 'tabler:heart',
      },
      {
        title: 'Hotel Control',
        description: 'Room thermostats, lighting control, door signs, energy management — ZigBee / Tuya powered for better guest experience.',
        icon: 'tabler:building-skyscraper',
      },
      {
        title: 'Software & Platforms',
        description: 'SmartOWON app, EdgeEco IoT platform, energy monitoring web, partner management — complete device management and data analytics.',
        icon: 'tabler:cloud-computing',
      },
    ]}
  />

  <!-- Why OWON -->
  <Content
    title="Why OWON"
    subtitle="Years of hardware R&D and manufacturing experience, delivering reliable products and customized solutions worldwide"
    items={[
      {
        title: 'Multi-Protocol',
        description: 'Simultaneously supports Tuya, MQTT open protocol, and ZigBee private solutions — adapts to diverse customer needs.',
      },
      {
        title: 'Global Compliance',
        description: 'Products certified with CE, FCC, RoHS and more, meeting regulatory requirements across global markets.',
      },
      {
        title: 'B2B Customization',
        description: 'OEM / ODM customization from hardware design to firmware, app, and cloud platform — full technical support.',
      },
      {
        title: 'Full-Stack IoT',
        description: 'End-to-end IoT solutions from devices to cloud, from mobile apps to web management dashboards.',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- CTA -->
  <CallToAction
    actions={[
      { variant: 'primary', text: 'Contact Sales', href: contactUrl, icon: 'tabler:mail' },
    ]}
  >
    <Fragment slot="title">
      Looking for a reliable smart IoT partner?
    </Fragment>
    <Fragment slot="subtitle">
      Contact us for product catalogues, technical documentation, and customized solution quotes
    </Fragment>
  </CallToAction>
</Layout>
