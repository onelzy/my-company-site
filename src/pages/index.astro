      <!-- Category cards -->
      <div class="grid gap-5 grid-cols-2 sm:grid-cols-3 lg:grid-cols-5">
        <!-- Smart Meters -->
        <a
          href="/products?dim=type&type=smart-meters"
          class="group flex flex-col items-center rounded-2xl bg-gray-50 dark:bg-slate-800 border-2 border-gray-200 dark:border-slate-700 p-6 hover:border-primary dark:hover:border-primary hover:shadow-lg hover:-translate-y-1 transition-all"
        >
          <div class="w-16 h-16 mb-4 rounded-xl bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center text-3xl group-hover:scale-110 transition-transform">
            ⚡
          </div>
          <h3 class="text-base font-bold text-default dark:text-slate-200 mb-1">Smart Meters</h3>
