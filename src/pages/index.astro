            <div class="w-20 h-20 mb-4 rounded-xl bg-rose-100 dark:bg-rose-900/30 flex items-center justify-center text-4xl">
              🏥
            </div>
            <h3 class="text-lg font-bold text-default dark:text-slate-200 mb-2">ZigBee Senior Care</h3>
            <p class="text-sm text-muted dark:text-slate-400 text-center mb-3">Non-contact health monitoring & emergency alert systems</p>
            <div class="flex gap-2">
              <span class="px-2.5 py-1 rounded-full text-xs font-semibold bg-indigo-100 dark:bg-indigo-900/40 text-indigo-700 dark:text-indigo-300">ZigBee</span>
            </div>
            <a href="/products?dim=type&type=senior-care" class="mt-4 text-sm text-primary hover:underline font-medium">View Senior Care &rarr;</a>
          </div>
          <!-- Dots -->
          <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-1.5 z-10">
            <button class="carousel-dot w-2 h-2 rounded-full bg-primary transition-all" data-dot="0" aria-label="Slide 1"></button>
            <button class="carousel-dot w-2 h-2 rounded-full bg-gray-400 dark:bg-slate-500 transition-all" data-dot="1" aria-label="Slide 2"></button>
            <button class="carousel-dot w-2 h-2 rounded-full bg-gray-400 dark:bg-slate-500 transition-all" data-dot="2" aria-label="Slide 3"></button>
            <button class="carousel-dot w-2 h-2 rounded-full bg-gray-400 dark:bg-slate-500 transition-all" data-dot="3" aria-label="Slide 4"></button>
