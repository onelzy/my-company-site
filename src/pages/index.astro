            <span class="px-2 py-0.5 rounded text-[10px] font-semibold bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300">Tuya</span>
            <span class="px-2 py-0.5 rounded text-[10px] font-semibold bg-teal-100 dark:bg-teal-900/40 text-teal-700 dark:text-teal-300">MQTT</span>
            <span class="px-2 py-0.5 rounded text-[10px] font-semibold bg-indigo-100 dark:bg-indigo-900/40 text-indigo-700 dark:text-indigo-300">ZigBee</span>
          </div>
        </a>

        <!-- Thermostats -->
        <a
          href="/products?dim=type&type=thermostats"
          class="group flex flex-col items-center rounded-2xl bg-gray-50 dark:bg-slate-800 border-2 border-gray-200 dark:border-slate-700 p-6 hover:border-primary dark:hover:border-primary hover:shadow-lg hover:-translate-y-1 transition-all"
        >
          <div class="w-16 h-16 mb-4 rounded-xl bg-orange-100 dark:bg-orange-900/30 flex items-center justify-center text-3xl group-hover:scale-110 transition-transform">
            🌡️
          </div>
          <h3 class="text-base font-bold text-default dark:text-slate-200 mb-1">Thermostats</h3>
          <p class="text-xs text-muted dark:text-slate-400 text-center">24V AC, boiler/TRV, touchscreen HVAC</p>
          <div class="flex gap-1.5 mt-3">
            <span class="px-2 py-0.5 rounded text-[10px] font-semibold bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300">Tuya</span>
            <span class="px-2 py-0.5 rounded text-[10px] font-semibold bg-teal-100 dark:bg-teal-900/40 text-teal-700 dark:text-teal-300">MQTT</span>
            <span class="px-2 py-0.5 rounded text-[10px] font-semibold bg-indigo-100 dark:bg-indigo-900/40 text-indigo-700 dark:text-indigo-300">ZigBee</span>
          </div>
        </a>

        <!-- Hotel Control -->
        <a
          href="/products?dim=type&type=hotel-control"
          class="group flex flex-col items-center rounded-2xl bg-gray-50 dark:bg-slate-800 border-2 border-gray-200 dark:border-slate-700 p-6 hover:border-primary dark:hover:border-primary hover:shadow-lg hover:-translate-y-1 transition-all"
        >
          <div class="w-16 h-16 mb-4 rounded-xl bg-purple-100 dark:bg-purple-900/30 flex items-center justify-center text-3xl group-hover:scale-110 transition-transform">
            🏨
          </div>
          <h3 class="text-base font-bold text-default dark:text-slate-200 mb-1">Hotel Control</h3>
          <p class="text-xs text-muted dark:text-slate-400 text-center">Room thermostats, lighting, door signs</p>
          <div class="flex gap-1.5 mt-3">
            <span class="px-2 py-0.5 rounded text-[10px] font-semibold bg-indigo-100 dark:bg-indigo-900/40 text-indigo-700 dark:text-indigo-300">ZigBee</span>
          </div>
        </a>

        <!-- Senior Care -->
        <a
          href="/products?dim=type&type=senior-care"
          class="group flex flex-col items-center rounded-2xl bg-gray-50 dark:bg-slate-800 border-2 border-gray-200 dark:border-slate-700 p-6 hover:border-primary dark:hover:border-primary hover:shadow-lg hover:-translate-y-1 transition-all"
        >
          <div class="w-16 h-16 mb-4 rounded-xl bg-rose-100 dark:bg-rose-900/30 flex items-center justify-center text-3xl group-hover:scale-110 transition-transform">
            🏥
          </div>
          <h3 class="text-base font-bold text-default dark:text-slate-200 mb-1">Senior Care</h3>
          <p class="text-xs text-muted dark:text-slate-400 text-center">Sleep monitors, emergency call, health tracking</p>
