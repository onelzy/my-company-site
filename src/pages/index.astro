---
export const prerender = false;

import Layout from '~/layouts/PageLayout.astro';

import { getPermalink } from '~/utils/permalinks';
import { SITE } from 'astrowind:config';
import { getCollection } from 'astro:content';

const metadata = {
  title: 'Smart IoT Devices for Your Industry — OWON Technology',
  ignoreTitleTemplate: true,
};

const productsUrl = getPermalink('/products');
const contactUrl = getPermalink('/contact-sales');
const developersUrl = getPermalink('/developers');
const solutionsUrl = getPermalink('/solutions');
const blogUrl = getPermalink('/blog');
const whatsappNumber = SITE.contact?.whatsapp || '8618650139895';

const heroSlides = [
  {
    title: 'Smart Energy Meters',
    subtitle: 'Tuya & MQTT — Precision metering for residential and commercial energy management',
    gradient: 'from-blue-700 via-blue-600 to-indigo-700',
    badges: ['Tuya', 'MQTT'],
    link: '/products?dim=type&type=smart-meters',
    linkText: 'Explore Smart Meters',
    imgSrc: '/images/products/pc321-ty.svg',
  },
  {
    title: 'Smart Thermostats',
    subtitle: 'Tuya & MQTT — Touchscreen HVAC control for North American and European markets',
    gradient: 'from-orange-600 via-red-500 to-rose-600',
    badges: ['Tuya', 'MQTT'],
    link: '/products?dim=type&type=thermostats',
    linkText: 'Explore Thermostats',
    imgSrc: '/images/products/pct513.svg',
  },
  {
    title: 'ZigBee Hotel Solution',
    subtitle: 'Room thermostats, lighting panels & door sign displays — full hotel room automation',
    gradient: 'from-purple-700 via-violet-600 to-indigo-700',
    badges: ['ZigBee'],
    link: '/products?dim=type&type=hotel-control',
    linkText: 'Explore Hotel Solutions',
    imgSrc: '/images/products/pc341-3m16s.svg',
  },
  {
    title: 'ZigBee Senior Care',
    subtitle: 'Non-contact sleep monitoring, emergency call & health tracking for elderly facilities',
    gradient: 'from-teal-700 via-emerald-600 to-green-700',
    badges: ['ZigBee'],
    link: '/products?dim=type&type=senior-care',
    linkText: 'Explore Senior Care',
    imgSrc: '/images/products/spm-915.svg',
  },
];

const blogPosts = await getCollection('post');
const latestPosts = blogPosts
  .filter((p) => !p.data.draft)
  .sort((a, b) => {
    const dateA = a.data.publishDate ? new Date(a.data.publishDate).getTime() : 0;
    const dateB = b.data.publishDate ? new Date(b.data.publishDate).getTime() : 0;
    return dateB - dateA;
  })
  .slice(0, 3);

const formatDate = (date: Date | undefined): string => {
  if (!date) return '';
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
};

const solutionSlides = [
  {
    icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
    title: 'Smart Hotels',
    subtitle: 'Complete room automation system for modern hospitality',
    desc: 'OWON hotel solution integrates room thermostats, lighting control panels, and door sign displays into a unified ZigBee mesh network. PMS integration and energy analytics included.',
    features: ['Room thermostat with guest profile', 'Lighting scene control panels', 'E-ink door sign displays', 'Central PMS integration', 'Per-room energy monitoring'],
    img: '/images/products/pct513.svg',
    color: 'from-blue-600 to-sky-500',
  },
  {
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
    title: 'Energy Management',
    subtitle: 'Enterprise-grade sub-metering and energy analytics',
    desc: 'Deploy OWON smart meters and multi-circuit monitors with Modbus/RS-485 or wireless connectivity. Real-time data feeds into EdgeEco cloud dashboard with automated reporting and anomaly detection.',
    features: ['Single & three-phase smart meters', 'Multi-circuit CT monitoring', 'Real-time cloud dashboard', 'Automated anomaly alerts', 'Tenant billing ready'],
    img: '/images/products/pc321-ty.svg',
    color: 'from-amber-600 to-orange-500',
  },
  {
    icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6',
    title: 'Smart Building',
    subtitle: 'HVAC optimization & intelligent lighting for commercial spaces',
    desc: 'OWON building automation covers HVAC control, lighting management, and access systems. ZigBee mesh ensures reliable device communication with centralized web dashboard for facility managers.',
    features: ['ZigBee HVAC thermostats', 'Zone-based lighting control', 'Access control integration', 'Web management dashboard', 'Energy saving analytics'],
    img: '/images/products/pc341-3m16s.svg',
    color: 'from-violet-600 to-purple-500',
  },
  {
    icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z',
    title: 'Senior Care',
    subtitle: 'Non-contact health monitoring for elderly facilities',
    desc: 'OWON senior care solution uses non-invasive sleep monitors, emergency call buttons, and fall detection sensors. AiJuan platform provides nurse station dashboard with real-time alerts and health trend reports.',
    features: ['Non-contact sleep monitoring', 'Emergency call system', 'Fall detection sensors', 'AiJuan nurse dashboard', 'Health trend reports'],
    img: '/images/products/spm-915.svg',
    color: 'from-rose-600 to-pink-500',
  },
  {
    icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z',
    title: 'Industrial IoT',
    subtitle: 'Factory monitoring & predictive maintenance',
    desc: 'OWON industrial solution connects machinery sensors via Modbus RS-485 and wireless networks. Edge computing gateway processes data locally with predictive alerts, feeding into SCADA and MES systems.',
    features: ['Modbus RS-485 connectivity', 'Edge computing gateway', 'Predictive maintenance alerts', 'SCADA/MES integration', 'Machinery energy tracking'],
    img: '/images/products/edgeeco.svg',
    color: 'from-emerald-600 to-teal-500',
  },
];
---

<Layout metadata={metadata}>
  <!-- ===== 1. Hero Carousel ===== -->
  <section class="hero-carousel relative w-full overflow-hidden" style="min-height: 500px;" id="heroSection">
    {heroSlides.map((slide, i) => (
      <div
        class={`hero-slide absolute inset-0 flex items-center transition-opacity duration-700 bg-gradient-to-r ${slide.gradient}`}
        class:list={[i === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0']}
        data-index={i}
      >
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 w-full py-16 lg:py-20">
          <div class="grid lg:grid-cols-2 gap-10 items-center">
            <div class="text-center lg:text-left">
              <div class="flex gap-2 justify-center lg:justify-start mb-4">
                {slide.badges.map((b) => (
                  <span class="inline-flex items-center rounded-full bg-white/20 backdrop-blur-sm px-3 py-1 text-sm font-semibold text-white border border-white/30">{b}</span>
                ))}
              </div>
              <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-4">{slide.title}</h1>
              <p class="text-lg md:text-xl text-white/80 mb-8 max-w-xl lg:mx-0">{slide.subtitle}</p>
              <div class="flex flex-wrap gap-3 justify-center lg:justify-start">
                <a href={slide.link} class="inline-flex items-center gap-2 rounded-full bg-white text-gray-900 hover:bg-gray-100 font-semibold px-8 py-3.5 transition-colors shadow-lg">{slide.linkText} &rarr;</a>
                <a href={contactUrl} class="inline-flex items-center gap-2 rounded-full bg-white/10 hover:bg-white/20 text-white font-semibold px-8 py-3.5 transition-colors border border-white/30 backdrop-blur-sm">Contact Sales</a>
              </div>
            </div>
            <div class="flex items-center justify-center">
              <div class="w-full max-w-sm rounded-2xl bg-white/10 backdrop-blur-sm p-6 border border-white/20">
                <img src={slide.imgSrc} alt={slide.title} class="w-full h-auto object-contain drop-shadow-2xl" loading="eager" />
              </div>
            </div>
          </div>
        </div>
      </div>
    ))}
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-20 flex gap-2.5">
      {heroSlides.map((_, i) => (
        <button class={`hero-dot w-3 h-3 rounded-full transition-all duration-300 border-2 border-white/60 ${i === 0 ? 'bg-white border-white scale-125' : 'bg-transparent hover:bg-white/40'}`} data-dot={i} aria-label={`Slide ${i + 1}`}></button>
      ))}
    </div>
  </section>

  <!-- ===== Trust Bar ===== -->
  <section class="py-8 bg-white dark:bg-slate-900 border-b border-gray-100 dark:border-slate-800">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap items-center justify-center lg:justify-between gap-6">
        <div class="flex flex-wrap justify-center gap-3">
          <span class="inline-flex items-center gap-1.5 rounded-full bg-green-100 dark:bg-green-900/40 px-3 py-1.5 text-sm font-medium text-green-700 dark:text-green-300"><span class="text-green-600 dark:text-green-400 text-xs font-bold">&#10003;</span> CE Certified</span>
          <span class="inline-flex items-center gap-1.5 rounded-full bg-blue-100 dark:bg-blue-900/40 px-3 py-1.5 text-sm font-medium text-blue-700 dark:text-blue-300"><span class="text-blue-600 dark:text-blue-400 text-xs font-bold">&#10003;</span> FCC Certified</span>
          <span class="inline-flex items-center gap-1.5 rounded-full bg-purple-100 dark:bg-purple-900/40 px-3 py-1.5 text-sm font-medium text-purple-700 dark:text-purple-300"><span class="text-purple-600 dark:text-purple-400 text-xs font-bold">&#10003;</span> RoHS Compliant</span>
        </div>
        <div class="flex gap-8">
          <div class="text-center"><div class="text-2xl font-bold text-primary dark:text-blue-300">1M+</div><div class="text-xs text-muted dark:text-slate-400">Devices Deployed</div></div>
          <div class="text-center"><div class="text-2xl font-bold text-primary dark:text-blue-300">50+</div><div class="text-xs text-muted dark:text-slate-400">Countries</div></div>
          <div class="text-center"><div class="text-2xl font-bold text-primary dark:text-blue-300">15+</div><div class="text-xs text-muted dark:text-slate-400">Years R&amp;D</div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 2. Product Categories ===== -->
  <section class="py-16 lg:py-20 bg-white dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-default dark:text-slate-100">Product Categories</h2>
      </div>
      <div class="grid gap-5 grid-cols-2 lg:grid-cols-4">
        {[
          { label: 'Smart Meters', desc: 'Single-phase, three-phase, multi-circuit DIN rail meters', img: '/images/products/pc321-ty.svg', link: '/products?dim=type&type=smart-meters', badges: ['Tuya', 'MQTT', 'ZigBee'] },
          { label: 'Thermostats', desc: '24V AC, boiler, touchscreen & ZigBee HVAC controllers', img: '/images/products/pct513.svg', link: '/products?dim=type&type=thermostats', badges: ['Tuya', 'MQTT', 'ZigBee'] },
          { label: 'Hotel Control', desc: 'Room thermostats, lighting, door signs & energy mgmt', img: '/images/products/pc341-3m16s.svg', link: '/products?dim=type&type=hotel-control', badges: ['ZigBee'] },
          { label: 'Senior Care', desc: 'Sleep monitors, emergency call, fall detection & nurse station', img: '/images/products/spm-915.svg', link: '/products?dim=type&type=senior-care', badges: ['ZigBee'] },
        ].map((cat) => (
          <a href={cat.link} class="group relative rounded-2xl bg-gray-50 dark:bg-slate-800 border border-gray-200 dark:border-slate-700 overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <!-- Image -->
            <div class="aspect-[4/3] bg-white dark:bg-slate-700/50 flex items-center justify-center p-6 group-hover:scale-105 transition-transform duration-500">
              <img src={cat.img} alt={cat.label} class="w-full h-full object-contain" loading="lazy" />
            </div>
            <!-- Content -->
            <div class="p-5">
              <h3 class="text-lg font-bold text-default dark:text-slate-200 mb-1">{cat.label}</h3>
              <p class="text-sm text-muted dark:text-slate-400 mb-3">{cat.desc}</p>
              <div class="flex gap-1.5 flex-wrap">
                {cat.badges.map((b) => (
                  <span class="px-2 py-0.5 rounded text-[10px] font-semibold bg-primary/10 dark:bg-primary/20 text-primary">{b}</span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href={productsUrl} class="inline-flex items-center gap-2 rounded-full bg-primary hover:bg-primary/90 text-white font-semibold px-8 py-3.5 transition-colors shadow-lg shadow-primary/25">View All Products &rarr;</a>
      </div>
    </div>
  </section>

  <!-- ===== 3. Solutions by Industry (Carousel) ===== -->
  <section class="py-16 lg:py-20 bg-gray-50 dark:bg-slate-800/50" id="solutionsSection">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between mb-10 gap-4">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-default dark:text-slate-100">Solutions by Industry</h2>
        </div>
        <div class="flex items-center gap-2">
          <button
            id="solPrev"
            class="w-10 h-10 rounded-full border-2 border-gray-300 dark:border-slate-600 flex items-center justify-center text-gray-500 dark:text-slate-400 hover:border-primary hover:text-primary transition-colors"
            aria-label="Previous solution"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          </button>
          <button
            id="solNext"
            class="w-10 h-10 rounded-full border-2 border-gray-300 dark:border-slate-600 flex items-center justify-center text-gray-500 dark:text-slate-400 hover:border-primary hover:text-primary transition-colors"
            aria-label="Next solution"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>
      </div>

      <!-- Carousel container -->
      <div class="relative overflow-hidden rounded-2xl bg-white dark:bg-slate-800 shadow-md border border-gray-200 dark:border-slate-700" id="solCarousel">
        <div class="flex transition-transform duration-500 ease-out" id="solTrack">
          {solutionSlides.map((sol, i) => (
            <div class="w-full flex-shrink-0" data-sol-index={i}>
              <div class="grid lg:grid-cols-2 gap-0">
                <!-- Text content -->
                <div class="p-8 lg:p-12 flex flex-col justify-center">
                  <div class="flex items-center gap-3 mb-4">
                    <div class={`w-12 h-12 rounded-xl bg-gradient-to-br ${sol.color} flex items-center justify-center shadow-lg`}>
                      <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={sol.icon}/>
                      </svg>
                    </div>
                    <div>
                      <h3 class="text-xl font-bold text-default dark:text-slate-200">{sol.title}</h3>
                      <p class="text-sm text-muted dark:text-slate-400">{sol.subtitle}</p>
                    </div>
                  </div>
                  <p class="text-muted dark:text-slate-400 leading-relaxed mb-6">{sol.desc}</p>
                  <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-2 mb-6">
                    {sol.features.map((f) => (
                      <li class="flex items-center gap-2 text-sm text-default dark:text-slate-300">
                        <svg class="w-4 h-4 text-green-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                        {f}
                      </li>
                    ))}
                  </ul>
                  <div>
                    <a href={solutionsUrl} class="inline-flex items-center gap-2 rounded-full bg-primary hover:bg-primary/90 text-white font-semibold px-6 py-3 transition-colors">Learn More &rarr;</a>
                  </div>
                </div>
                <!-- Image -->
                <div class={`bg-gradient-to-br ${sol.color} flex items-center justify-center p-8 lg:p-12 min-h-[280px]`}>
                  <img src={sol.img} alt={sol.title} class="w-full max-w-xs h-auto object-contain drop-shadow-2xl" loading="lazy" />
                </div>
              </div>
            </div>
          ))}
        </div>

        <!-- Dots -->
        <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2 z-10">
          {solutionSlides.map((_, i) => (
            <button class={`sol-dot w-2 h-2 rounded-full transition-all ${i === 0 ? 'bg-primary scale-125' : 'bg-gray-300 dark:bg-slate-600'}`} data-sol-dot={i} aria-label={`Solution ${i + 1}`}></button>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 4. About OWON ===== -->
  <section class="py-16 lg:py-20 bg-white dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-12 text-default dark:text-slate-100">About OWON</h2>

      <!-- Top row: Company + Factory Video -->
      <div class="grid lg:grid-cols-2 gap-10 mb-12">
        <!-- Company + Stats -->
        <div>
          <p class="text-sm text-muted dark:text-slate-400 leading-relaxed mb-6">
            XIAMEN OWON TECHNOLOGY CO.,LTD is a leading IoT device manufacturer with 15+ years of R&D expertise. We design, manufacture, and deliver smart energy meters, thermostats, and IoT solutions to B2B customers across 50+ countries.
          </p>
          <div class="grid grid-cols-4 gap-4 mb-6">
            <div class="text-center"><div class="text-2xl font-bold text-primary">1M+</div><div class="text-xs text-muted dark:text-slate-400">Devices</div></div>
            <div class="text-center"><div class="text-2xl font-bold text-primary">50+</div><div class="text-xs text-muted dark:text-slate-400">Countries</div></div>
            <div class="text-center"><div class="text-2xl font-bold text-primary">15+</div><div class="text-xs text-muted dark:text-slate-400">Years R&amp;D</div></div>
            <div class="text-center"><div class="text-2xl font-bold text-primary">200+</div><div class="text-xs text-muted dark:text-slate-400">Employees</div></div>
          </div>
          <!-- Factory features -->
          <div>
            <h3 class="text-sm font-semibold text-default dark:text-slate-200 uppercase tracking-wider mb-3">Factory</h3>
            <ul class="space-y-2">
              <li class="flex items-start gap-2 text-sm text-muted dark:text-slate-400"><span class="text-green-500 shrink-0 mt-0.5 font-bold">&#10003;</span>20,000m&sup2; manufacturing facility in Xiamen, China</li>
              <li class="flex items-start gap-2 text-sm text-muted dark:text-slate-400"><span class="text-green-500 shrink-0 mt-0.5 font-bold">&#10003;</span>ISO 9001 certified quality management</li>
              <li class="flex items-start gap-2 text-sm text-muted dark:text-slate-400"><span class="text-green-500 shrink-0 mt-0.5 font-bold">&#10003;</span>In-house SMT production lines</li>
              <li class="flex items-start gap-2 text-sm text-muted dark:text-slate-400"><span class="text-green-500 shrink-0 mt-0.5 font-bold">&#10003;</span>Dedicated reliability testing lab</li>
              <li class="flex items-start gap-2 text-sm text-muted dark:text-slate-400"><span class="text-green-500 shrink-0 mt-0.5 font-bold">&#10003;</span>24/7 production capability</li>
            </ul>
          </div>
        </div>

        <!-- Factory Video -->
        <div class="rounded-2xl bg-slate-800 dark:bg-slate-700 aspect-video flex items-center justify-center cursor-pointer hover:bg-slate-700 dark:hover:bg-slate-600 transition-colors">
          <div class="text-center">
            <div class="w-16 h-16 mx-auto rounded-full bg-white/20 flex items-center justify-center mb-4">
              <svg class="w-7 h-7 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"></path></svg>
            </div>
            <p class="text-white font-medium text-lg">Factory Tour — Xiamen, China</p>
            <p class="text-slate-400 text-sm mt-1">Click to play</p>
          </div>
        </div>
      </div>

      <!-- Certifications -->
      <div>
        <h3 class="text-sm font-semibold text-default dark:text-slate-200 uppercase tracking-wider mb-3 text-center">Certifications</h3>
        <div class="flex flex-wrap justify-center gap-2">
          {['CE','FCC','RoHS','UKCA','RED','ISO 9001','ISO 14001','ISO 45001','BSCI'].map((c) => (
            <span class="inline-flex items-center gap-1.5 rounded-full bg-green-100 dark:bg-green-900/40 px-3 py-1.5 text-xs font-medium text-green-700 dark:text-green-300"><span class="text-green-600 dark:text-green-400 text-xs font-bold">&#10003;</span> {c}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 5. Latest from Blog ===== -->
  <section class="py-16 lg:py-20 bg-gray-50 dark:bg-slate-800/50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between mb-10 gap-4">
        <h2 class="text-3xl md:text-4xl font-bold text-default dark:text-slate-100">Latest from Blog</h2>
        <a href={blogUrl} class="inline-flex items-center gap-1 text-primary hover:underline font-medium text-sm whitespace-nowrap">View All &rarr;</a>
      </div>
      <div class="grid gap-6 sm:grid-cols-3">
        {latestPosts.map((post) => (
          <a href={`/blog/${post.id}`} class="group flex flex-col rounded-xl bg-gray-50 dark:bg-slate-800 border border-gray-200 dark:border-slate-700 overflow-hidden hover:shadow-md transition-all">
            {post.data.image ? (
              <div class="aspect-[16/10] overflow-hidden">
                <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              </div>
            ) : (
              <div class="aspect-[16/10] bg-gradient-to-br from-primary/20 to-primary/5 dark:from-primary/10 dark:to-transparent flex items-center justify-center">
                <svg class="w-10 h-10 text-primary/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
              </div>
            )}
            <div class="p-5 flex-1">
              <time class="text-xs text-muted dark:text-slate-400 mb-2">{formatDate(post.data.publishDate)}</time>
              <h3 class="font-semibold text-default dark:text-slate-200 group-hover:text-primary transition-colors mb-2 line-clamp-2">{post.data.title}</h3>
              <p class="text-sm text-muted dark:text-slate-400 leading-relaxed line-clamp-2 flex-1">{post.data.excerpt}</p>
              <span class="inline-flex items-center gap-1 mt-4 text-sm font-medium text-primary group-hover:underline">Read more &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== 6. Developers ===== -->
  <section class="py-16 lg:py-20 bg-white dark:bg-slate-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-default dark:text-slate-100 mb-8">Open API. Full SDKs. Integrate in hours.</h2>
      <div>
        <a href={developersUrl} class="inline-flex items-center gap-2 rounded-full bg-primary hover:bg-primary/90 text-white font-medium px-8 py-4 transition-colors">Explore Developer Docs &rarr;</a>
      </div>
    </div>
  </section>

</Layout>

<script>
  // ===== Hero Carousel =====
  (function () {
    var section = document.getElementById('heroSection');
    if (!section) return;
    var slides = section.querySelectorAll('.hero-slide');
    var dots = section.querySelectorAll('.hero-dot');
    if (slides.length === 0) return;
    var current = 0, timer;
    function showSlide(i) {
      slides.forEach(function(s,j){s.classList.toggle('opacity-100',j===i);s.classList.toggle('z-10',j===i);s.classList.toggle('opacity-0',j!==i);s.classList.toggle('z-0',j!==i);});
      dots.forEach(function(d,j){d.classList.toggle('bg-white',j===i);d.classList.toggle('border-white',j===i);d.classList.toggle('scale-125',j===i);d.classList.toggle('bg-transparent',j!==i);});
      current = i;
    }
    function next() { showSlide((current + 1) % slides.length); }
    function start() { stop(); timer = setInterval(next, 5000); }
    function stop() { if (timer) clearInterval(timer); }
    dots.forEach(function(d){d.addEventListener('click',function(){showSlide(parseInt(d.getAttribute('data-dot'),10));start();});});
    start();
  })();

  // ===== Solutions Carousel =====
  (function () {
    var track = document.getElementById('solTrack');
    var prev = document.getElementById('solPrev');
    var next = document.getElementById('solNext');
    var dots = document.querySelectorAll('.sol-dot');
    if (!track || !prev || !next) return;
    var slides = track.querySelectorAll('[data-sol-index]');
    var total = slides.length;
    var current = 0;

    function goTo(i) {
      if (i < 0) i = total - 1;
      if (i >= total) i = 0;
      current = i;
      track.style.transform = 'translateX(-' + (i * 100) + '%)';
      dots.forEach(function(d,j){d.classList.toggle('bg-primary',j===i);d.classList.toggle('scale-125',j===i);d.classList.toggle('bg-gray-300',j!==i);d.classList.toggle('dark:bg-slate-600',j!==i);});
    }

    prev.addEventListener('click', function(){goTo(current - 1);});
    next.addEventListener('click', function(){goTo(current + 1);});
    dots.forEach(function(d){d.addEventListener('click',function(){goTo(parseInt(d.getAttribute('data-sol-dot'),10));});});
  })();
</script>
