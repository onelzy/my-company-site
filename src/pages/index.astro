              🌡️
            </div>
            <h3 class="text-lg font-bold text-default dark:text-slate-200 mb-2">Smart Thermostat</h3>
            <p class="text-sm text-muted dark:text-slate-400 text-center mb-3">Touchscreen HVAC control for North American markets</p>
            <div class="flex gap-2">
              <span class="px-2.5 py-1 rounded-full text-xs font-semibold bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-300">Tuya</span>
              <span class="px-2.5 py-1 rounded-full text-xs font-semibold bg-teal-100 dark:bg-teal-900/40 text-teal-700 dark:text-teal-300">MQTT</span>
            </div>
            <a href="/products?dim=type&type=thermostats" class="mt-4 text-sm text-primary hover:underline font-medium">View Thermostats &rarr;</a>
          </div>
          <!-- Slide 3: Zigbee Hotel Solution -->
