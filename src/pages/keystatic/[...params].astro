---
import { Keystatic } from './_keystatic-page.js';
import type { GetStaticPaths } from 'astro';

export const prerender = false;

// Return empty array: 0 static paths, all requests handled by SSR worker.
// Required because @astrojs/cloudflare prerender server demands getStaticPaths
// even for prerender=false routes.
export const getStaticPaths: GetStaticPaths = () => [];
---

<Keystatic client:only="react" />
