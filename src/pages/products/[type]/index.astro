---
import type { GetStaticPaths } from 'astro';
import type { Product } from '~/types';
import { getCollection } from 'astro:content';
import PageLayout from '~/layouts/PageLayout.astro';
import ProductGrid from '~/components/products/ProductGrid.astro';
import ProductFilter from '~/components/products/ProductFilter.astro';
import {
  PRODUCT_TYPE_LABELS,
  getLocalizedLabel,
  getAllProductTypes,
} from '~/utils/products';

export const prerender = true;

export const getStaticPaths: GetStaticPaths = () => {
  const locales = ['en', 'zh', 'es', 'ru', 'fr', 'de', 'ar', 'pt'];
  const types = getAllProductTypes();
  const paths: { params: { type: string }; props: { locale: string } }[] = [];

  for (const locale of locales) {
    for (const type of types) {
      paths.push({
        params: { type },
        props: { locale },
      });
    }
  }
  return paths;
};

const { type } = Astro.params;
const { locale } = Astro.props as { locale: string };

const allProducts = await getCollection('products');

const products: Product[] = allProducts
  .filter((p) => p.data.language === locale && p.data.productType === type)
  .map((p) => ({
    ...p.data,
    id: p.id,
    slug: p.id.split('/').pop()?.replace('.mdoc', '') || p.data.name.toLowerCase().replace(/\s+/g, '-'),
    collection: 'products' as const,
    data: p.data,
  }));

const typeLabel = getLocalizedLabel(PRODUCT_TYPE_LABELS, type, locale);
const title = `${typeLabel} — ${locale === 'zh' ? 'OWON Technology' : 'OWON Technology'}`;
const description = locale === 'zh'
  ? `${typeLabel}系列产品，涵盖${products.map(p => p.name).slice(0, 3).join('、')}等型号`
  : `${typeLabel} product line including ${products.map(p => p.name).slice(0, 3).join(', ')}`;
---

<PageLayout metadata={{ title, description }}>
  <section class="py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="mb-6 text-sm text-muted dark:text-slate-400">
        <a href={`/${locale}/products`} class="hover:text-primary transition-colors">
          {locale === 'zh' ? '全部产品' : 'All Products'}
        </a>
        <span class="mx-2" aria-hidden="true">/</span>
        <span class="text-default dark:text-slate-200 font-medium">{typeLabel}</span>
      </nav>

      <!-- Page Header -->
      <div class="mb-10">
        <h1 class="text-3xl font-bold text-default dark:text-slate-100 sm:text-4xl">
          {typeLabel}
        </h1>
        <p class="mt-3 text-lg text-muted dark:text-slate-400 max-w-3xl">
          {products.length} {locale === 'zh' ? '个产品' : 'products'}
        </p>
      </div>

      <div class="lg:grid lg:grid-cols-[280px_1fr] lg:gap-10">
        <!-- Filter Sidebar -->
        <aside class="hidden lg:block">
          <ProductFilter
            filters={{ productType: type as Product['productType'] }}
            locale={locale}
            class="sticky top-24"
          />
        </aside>

        <!-- Product Grid -->
        <ProductGrid products={products} baseUrl={`/${locale}/products`} />
      </div>
    </div>
  </section>
</PageLayout>
