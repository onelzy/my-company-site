---
// products/[slug].astro — Product detail page
// Data from pre-generated src/data/products.ts
import type { Product } from '~/types';
import PageLayout from '~/layouts/PageLayout.astro';
import Image from '~/components/common/Image.astro';
import WhatsAppButton from '~/components/common/WhatsAppButton.astro';
import ProductGrid from '~/components/products/ProductGrid.astro';
import { SITE } from 'astrowind:config';
import { PRODUCT_TYPE_LABELS, TECH_SOLUTION_LABELS, SPEC_LABELS, getLocalizedLabel } from '~/utils/products';
import { renderMarkdown } from '~/utils/parseMdoc';
import { products as rawProducts } from '~/data/products';

export const prerender = false;

const { slug } = Astro.params;
const entry = rawProducts.find((p) => {
  const dataSlug = (p.data as Record<string, unknown>).slug as { name?: string; slug?: string } | undefined;
  return p.slug === slug || dataSlug?.slug === slug;
});
if (!entry) return Astro.redirect('/404', 302);

const allProducts = rawProducts.map((p) => ({
  ...p.data,
  id: p.slug,
  slug: p.slug,
  collection: 'products' as const,
  data: p.data,
}));

const product: Product = {
  ...entry.data,
  id: entry.slug,
  slug: entry.slug,
  collection: 'products' as const,
  data: entry.data,
};
const { name, model, description } = entry.data as Record<string, unknown>;
const productType = (entry.data as Record<string, unknown>).productType as string | undefined;
const techSolution = (entry.data as Record<string, unknown>).techSolution as string | undefined;
const communication = ((entry.data as Record<string, unknown>).communication ?? []) as string[];
const ecosystem = ((entry.data as Record<string, unknown>).ecosystem ?? []) as string[];
const specs = ((entry.data as Record<string, unknown>).specs ?? {}) as Record<string, string>;
const faqs = ((entry.data as Record<string, unknown>).faqs ?? []) as Array<{q: string; a: string}>;
const specEntries = Object.entries(specs).filter(([, v]) => v !== undefined && v !== null && String(v).trim() !== '');

const specFieldLabels: Record<string, string> = {
  accuracy: 'Accuracy',
  voltage: 'Voltage',
  current: 'Current',
  frequency: 'Frequency',
  powerSupply: 'Power Supply',
  display: 'Display',
  dimensions: 'Dimensions',
  weight: 'Weight',
  operatingTemp: 'Operating Temp',
  protocol: 'Protocol',
  certification: 'Certification',
  warranty: 'Warranty',
};
const relatedProducts: Product[] = allProducts
  .filter(
    (p) =>
      p.slug !== slug &&
      ((productType && (p as Record<string, unknown>).productType === productType) ||
        (techSolution && (p as Record<string, unknown>).techSolution === techSolution))
  )
  .slice(0, 4) as Product[];

const metaTitle = `${name} — OWON Technology`;
const metaDescription = description?.trim() || `Learn about ${name} specifications and features.`;
const typeLabel = productType ? getLocalizedLabel(PRODUCT_TYPE_LABELS, productType, 'en') : '';
const htmlContent = renderMarkdown(entry.body || '');
const imageSrc = (entry.data as Record<string, unknown>).image as string | undefined;
const images = ((entry.data as Record<string, unknown>).images as string[]) || (imageSrc ? [imageSrc] : []);
const hasImage = images.length > 0;
const galleryMode = images.length > 1;

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name,
  description: metaDescription,
  sku: model || product.slug,
  brand: { '@type': 'Brand', name: 'OWON Technology' },
  ...(hasImage && { image: `${Astro.url.origin}${images[0]}` }),
  offers: { '@type': 'Offer', availability: 'https://schema.org/InStock' },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${Astro.url.origin}/` },
    { '@type': 'ListItem', position: 2, name: 'Products', item: `${Astro.url.origin}/products` },
    ...(typeLabel ? ([{ '@type': 'ListItem', position: 3, name: typeLabel }] as const) : []),
    { '@type': 'ListItem', position: typeLabel ? 4 : 3, name },
  ],
};

// Dynamic FAQ content based on product's actual communication/ecosystem tags
const productProtocol = (specs?.protocol ?? '') as string;
const prodComm = communication.length > 0 ? communication.map(c => c.toUpperCase()).join(', ') : '';
const prodEco = ecosystem.length > 0 ? ecosystem.map(c => c.charAt(0).toUpperCase() + c.slice(1)).join(' & ') : '';
const isTuyaWifi = ecosystem.includes('tuya') && communication.includes('wifi');

const protocolAnswer = isTuyaWifi
  ? `This model supports ${productProtocol || prodComm || 'WiFi'}, fully compatible with Tuya Smart and Smart Life apps.`
  : `This model supports ${productProtocol || prodComm || 'standard communication protocols'}.`;

const integrationAnswer = prodEco
  ? `Yes. ${prodEco} compatibility enables integration with most energy management platforms. Custom SDK available for advanced integration.`
  : 'Yes. Standard protocol integration with major building and energy management systems. Custom SDK available.';

const cloudAnswer = isTuyaWifi
  ? 'No — fully local operation. Remote monitoring available via the Tuya Smart / Smart Life app. WiFi required for cloud connectivity.'
  : 'No. Supports fully local operation. Cloud connectivity is optional.';

const faqItems = (() => {
  // Product-specific FAQs from mdoc frontmatter take priority
  if (faqs.length > 0) {
    return faqs.map(f => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    }));
  }
  const faqsGeneric: Record<string, Array<{q:string; a:string}>> = {
    'smart-meters': [
      {q:'What communication protocols are supported?', a: protocolAnswer},
      {q:'What is the accuracy class?', a:'Most OWON meters achieve Class 1.0 or Class 0.5S accuracy, compliant with IEC 62053-21/22 standards.'},
      {q:'Can these meters integrate with existing BMS/EMS?', a: integrationAnswer},
      {q:'Is cloud connectivity required?', a: cloudAnswer},
    ],
    'thermostats': [
      {q:'Which HVAC systems are compatible?', a:'OWON thermostats work with water-based heating/cooling, fan coil units, heat pumps, and boiler systems.'},
      {q:'Can I control multiple zones?', a:'Yes. Each thermostat controls its zone independently with unified multi-zone app management.'},
      {q:'Does it support schedules and automation?', a:'Yes. Daily/weekly schedules, geo-fencing, scenes, and MQTT-based custom automation.'},
      {q:'What happens if WiFi goes down?', a:'Local schedules and manual control continue to work. Settings are stored on-device.'},
    ],
    'senior-care': [
      {q:'How does non-contact monitoring work?', a:'mmWave radar and passive infrared detect presence, breathing, heart rate, and movement without cameras or wearables.'},
      {q:'Is the system privacy-compliant?', a:'Yes. No cameras or microphones. Radar-based sensing is fully GDPR and HIPAA compatible.'},
      {q:'How are alerts delivered?', a:'Push notification, SMS, email, and phone call to designated caregivers with multi-level escalation.'},
      {q:'Can I install it myself?', a:'Devices are plug-and-play. Professional installation recommended for multi-room and nurse call integration.'},
    ],
    'hotel-control': [
      {q:'Does installation require rewiring?', a:'Most devices are wireless and mount on existing wall boxes. No new wiring needed.'},
      {q:'Can it integrate with existing PMS systems?', a:'Yes. APIs and MQTT bridges for major Property Management Systems.'},
      {q:'How many rooms can one system manage?', a:'EdgeEco scales to thousands of rooms. ZigBee mesh supports 200+ devices per coordinator.'},
      {q:'Is there a guest-facing app?', a:'Yes. Branded mobile app or in-room touch panel for guest control of temperature, lighting, and services.'},
    ],
    'software-platforms': [
      {q:'Is the platform white-label ready?', a:'Yes. Custom branding, domains, white-label apps, and tailored UI for OEM/ODM partners.'},
      {q:'What APIs are available?', a:'REST API, MQTT broker, WebSocket streaming, webhooks. SDKs for Python, Node.js, Java, embedded C.'},
      {q:'Is it cloud-based or on-premise?', a:'Both. EdgeEco Cloud (multi-tenant SaaS) and EdgeEco On-Premise for air-gapped environments.'},
      {q:'Can I manage devices from other brands?', a:'Yes. Multi-vendor device management via MQTT and Modbus. Contact us for specific compatibility.'},
    ],
  };
  const currentType = (typeof productType === 'string' ? productType : '') || 'smart-meters';
  return (faqsGeneric[currentType] || faqsGeneric['smart-meters']).map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  }));
})();

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems,
};
---
<PageLayout metadata={{ title: metaTitle, description: metaDescription }}>
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <section class="py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-8 text-sm text-muted dark:text-slate-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span class="mx-2">/</span>
        <a href="/products" class="hover:text-primary transition-colors">Products</a>
        {
          productType && (
            <>
              <>
                <span class="mx-2">/</span>
                <span class="text-default dark:text-slate-200 font-medium">{typeLabel}</span>
              </>
            </>
          )
        }
        <span class="mx-2">/</span>
        <span class="text-default dark:text-slate-200 font-medium">{name}</span>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 mb-16">
        <!-- Left: Image Gallery -->
        <div>
          <div
            class="relative aspect-square rounded-xl bg-gray-100 dark:bg-slate-800 overflow-hidden border border-gray-200 dark:border-slate-700"
          >
            {
              hasImage ? (
                <Image
                  src={images[0]}
                  alt={name}
                  layout="cover"
                  class="absolute inset-0 w-full h-full"
                  width={800}
                  height={800}
                  format="webp"
                  loading="eager"
                  decoding="async"
                />
              ) : (
                <div class="absolute inset-0 flex items-center justify-center text-muted dark:text-slate-500">
                  <svg class="w-24 h-24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                </div>
              )
            }
          </div>

          <!-- Thumbnail Strip -->
          {
            galleryMode && (
              <div class="flex gap-2 mt-3 overflow-x-auto pb-1" id="product-gallery-thumbs">
                {images.map((img, i) => (
                  <button
                    type="button"
                    data-index={i}
                    data-src={img}
                    class={`flex-shrink-0 w-16 h-16 rounded-lg border-2 overflow-hidden bg-gray-100 dark:bg-slate-800 transition-all ${
                      i === 0 ? 'border-primary' : 'border-gray-200 dark:border-slate-600 hover:border-primary/50'
                    }`}
                  >
                    <Image src={img} alt={`${name} ${i + 1}`} width={64} height={64} class="w-full h-full object-cover" />
                  </button>
                ))}
              </div>
            )
          }

          <!-- Protocol & Ecosystem Badges -->
          <div class="flex flex-wrap gap-1.5 mt-4">
            {
              communication.map((m: string) => (
                <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded text-xs font-semibold bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300 border border-green-200 dark:border-green-800">
                  {getLocalizedLabel(SPEC_LABELS, m, 'en')}
                </span>
              ))
            }
            {
              ecosystem.map((e: string) => (
                <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded text-xs font-semibold bg-purple-50 dark:bg-purple-900/20 text-purple-700 dark:text-purple-300 border border-purple-200 dark:border-purple-800">
                  {getLocalizedLabel(SPEC_LABELS, e, 'en')}
                </span>
              ))
            }
          </div>
        </div>

        <!-- Right: Product Info -->
        <div class="flex flex-col justify-center">
          <h1 class="text-3xl font-bold text-default dark:text-slate-100 sm:text-4xl lg:text-5xl mb-3">{name}</h1>
          {
            model && (
              <p class="text-lg font-mono text-muted dark:text-slate-400 mb-4 bg-gray-100 dark:bg-slate-800 inline-block self-start px-3 py-1 rounded-md border border-gray-200 dark:border-slate-700">
                {model}
              </p>
            )
          }
          {
            description && (
              <p class="text-base text-default dark:text-slate-300 leading-relaxed mb-6 max-w-xl">{description}</p>
            )
          }
          <div class="flex flex-wrap gap-2">
            {
              productType && (
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-primary/10 text-primary border border-primary/20">
                  {typeLabel}
                </span>
              )
            }
            {
              techSolution && (
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300 border border-blue-200 dark:border-blue-700">
                  {getLocalizedLabel(TECH_SOLUTION_LABELS, techSolution, 'en')}
                </span>
              )
            }
            {
              communication.map((m: string) => (
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-300 border border-green-200 dark:border-green-700">
                  {getLocalizedLabel(SPEC_LABELS, m, 'en')}
                </span>
              ))
            }
            {
              ecosystem.map((e: string) => (
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-300 border border-purple-200 dark:border-purple-700">
                  {getLocalizedLabel(SPEC_LABELS, e, 'en')}
                </span>
              ))
            }
          </div>
        </div>
      </div>

      <div class="space-y-16">
        <section>
          <h2
            class="text-2xl font-bold text-default dark:text-slate-100 mb-6 pb-2 border-b border-gray-200 dark:border-slate-700"
          >
            Overview
          </h2>
          <div
            class="prose prose-lg dark:prose-invert max-w-none prose-headings:text-default dark:prose-headings:text-slate-100 prose-p:text-default dark:prose-p:text-slate-300 prose-strong:text-default dark:prose-strong:text-slate-200 prose-li:text-default dark:prose-li:text-slate-300 prose-a:text-primary prose-code:bg-gray-100 dark:prose-code:bg-slate-800 prose-code:text-default prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm"
          >
            {
              htmlContent ? (
                <Fragment set:html={htmlContent} />
              ) : (
                <p class="text-muted dark:text-slate-400 italic">No overview information available.</p>
              )
            }
          </div>
        </section>
        <section>
          <h2
            class="text-2xl font-bold text-default dark:text-slate-100 mb-6 pb-2 border-b border-gray-200 dark:border-slate-700"
          >
            Specifications
          </h2>
          {
            specEntries.length > 0 ? (
              <div class="rounded-xl border border-gray-200 dark:border-slate-700 overflow-hidden bg-white dark:bg-slate-800 shadow-sm">
                <table class="w-full text-sm">
                  <tbody>
                    {specEntries.map(([key, value]) => (
                      <tr class="border-b border-gray-100 dark:border-slate-700 last:border-b-0 transition-colors hover:bg-gray-50 dark:hover:bg-slate-800/60">
                        <th class="px-5 py-3 text-left font-medium text-muted dark:text-slate-400 bg-gray-50 dark:bg-slate-800/40 w-1/3">
                          {specFieldLabels[key] ?? key}
                        </th>
                        <td class="px-5 py-3 text-default dark:text-slate-200 font-mono">{String(value)}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            ) : (
              <p class="text-muted dark:text-slate-400 italic">No specifications available.</p>
            )
          }
        </section>
        <!-- Key Benefits -->
        <section class="mt-12">
          <h2 class="text-2xl font-bold text-default dark:text-slate-100 mb-6 pb-2 border-b border-gray-200 dark:border-slate-700">Key Benefits</h2>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            {
              (() => {
                const isTuyaWifiEco = ecosystem.includes('tuya') && communication.includes('wifi');
                const benefits: Record<string, Array<{icon:string; title:string; desc:string}>> = {
                  'smart-meters': isTuyaWifiEco ? [
                    {icon:'📊', title:'Real-Time Monitoring', desc:'Track energy consumption in real time across single and three-phase circuits.'},
                    {icon:'📱', title:'Tuya Ecosystem', desc:'Fully compatible with Tuya Smart and Smart Life apps for monitoring, control, and automation.'},
                    {icon:'⚡', title:'Bi-Directional Metering', desc:'Measures both energy consumed and produced — ideal for solar PV net metering.'},
                    {icon:'🛡️', title:'Certified Quality', desc:'CE, FCC, RoHS certified. Built for commercial and industrial environments.'},
                  ] : [
                    {icon:'📊', title:'Real-Time Monitoring', desc:'Track energy consumption with real-time data across single and three-phase circuits.'},
                    {icon:'💰', title:'Cost Allocation', desc:'Sub-meter individual tenants, departments, or equipment with granular kWh data.'},
                    {icon:'🔌', title:'Easy Integration', desc:'Seamless protocol connectivity for EMS and BMS platform integration.'},
                    {icon:'🛡️', title:'Certified Quality', desc:'CE, FCC, RoHS certified. Built for commercial and industrial environments.'},
                  ],
                  'thermostats': [
                    {icon:'🎯', title:'Precision Control', desc:'±0.5°C accuracy with PID algorithms for consistent comfort and efficiency.'},
                    {icon:'⚡', title:'Energy Savings', desc:'Smart scheduling and occupancy detection reduce HVAC energy use by up to 30%.'},
                    {icon:'📱', title:'Remote Management', desc:'Control and monitor temperature zones from anywhere via app or web dashboard.'},
                    {icon:'🔄', title:'Open Protocol', desc:'Seamless protocol integration with any building management system.'},
                  ],
                  'senior-care': [
                    {icon:'🫀', title:'Non-Contact Monitoring', desc:'Detect heart rate, breathing, and sleep patterns without wearables or cameras.'},
                    {icon:'🚨', title:'Instant Alerts', desc:'Push notifications to caregivers and family within seconds of detected anomalies.'},
                    {icon:'📈', title:'Health Trends', desc:'Long-term data tracking for proactive care and early intervention.'},
                    {icon:'🔒', title:'Privacy First', desc:'No cameras, no audio recording — radar-based sensing protects resident dignity.'},
                  ],
                  'hotel-control': [
                    {icon:'🛏️', title:'Guest Comfort', desc:'In-room thermostats, lighting panels, and door signage for a premium experience.'},
                    {icon:'💡', title:'Energy Efficiency', desc:'Auto-off when rooms are vacant. Reduce energy costs by 25-40%.'},
                    {icon:'🏨', title:'Central Management', desc:'Monitor and control hundreds of rooms from a single dashboard.'},
                    {icon:'🔧', title:'Easy Retrofit', desc:'Wireless installation on existing wiring. No structural changes needed.'},
                  ],
                  'software-platforms': [
                    {icon:'☁️', title:'Cloud-Native', desc:'Scalable IoT platform with multi-tenant architecture for B2B deployments.'},
                    {icon:'🔗', title:'Open API', desc:'RESTful APIs, MQTT bridges, and WebSocket streaming for seamless integration.'},
                    {icon:'📊', title:'Data Analytics', desc:'Real-time dashboards, historical reports, and exportable data for business intelligence.'},
                    {icon:'🎨', title:'White-Label Ready', desc:'Custom branding, custom domains, and tailored UI for your business identity.'},
                  ],
                };
                const currentType = (typeof productType === 'string' ? productType : '') || 'smart-meters';
                const items = benefits[currentType] || benefits['smart-meters'];
                return items.map(b => (
                  <div class="group p-5 rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 hover:border-primary/30 dark:hover:border-primary/30 hover:shadow-sm transition-all">
                    <span class="text-2xl mb-3 block">{b.icon}</span>
                    <h4 class="font-semibold text-sm text-default dark:text-slate-200 mb-1.5">{b.title}</h4>
                    <p class="text-xs text-muted dark:text-slate-400 leading-relaxed">{b.desc}</p>
                  </div>
                ));
              })()
            }
          </div>
        </section>

        <!-- Ideal For -->
        <section class="mt-12">
          <h2 class="text-2xl font-bold text-default dark:text-slate-100 mb-2 pb-2 border-b border-gray-200 dark:border-slate-700">Ideal For</h2>
          <p class="text-sm text-muted dark:text-slate-400 mb-6">Common deployment scenarios where {name} delivers the most value.</p>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {
              (() => {
                const scenarios = {
                  'smart-meters': [
                    {icon:'🏢', title:'Commercial Buildings', desc:'Sub-meter HVAC, lighting, and plug loads across tenant spaces for accurate billing.'},
                    {icon:'🏭', title:'Industrial Facilities', desc:'Monitor production line energy consumption, identify waste, and optimize operations.'},
                    {icon:'☀️', title:'Solar & Storage', desc:'Track generation, consumption, and grid export with bi-directional metering.'},
                    {icon:'🏗️', title:'New Construction', desc:'Meet energy code requirements with integrated sub-metering from day one.'},
                    {icon:'🔋', title:'EV Charging', desc:'Monitor EV charger circuits for usage-based billing and load management.'},
                    {icon:'🏠', title:'Multi-Tenant Residential', desc:'Fair, transparent energy billing for apartments and condominiums.'},
                  ],
                  'thermostats': [
                    {icon:'🏨', title:'Hotels & Resorts', desc:'In-room climate control with occupancy-based setbacks for guest comfort and savings.'},
                    {icon:'🏢', title:'Office Buildings', desc:'Zone-based temperature management with schedules aligned to business hours.'},
                    {icon:'🏥', title:'Healthcare', desc:'Precise temperature control for patient rooms, labs, and pharmaceutical storage.'},
                    {icon:'🏫', title:'Schools', desc:'Classroom comfort with automatic setbacks during holidays and weekends.'},
                    {icon:'🏠', title:'Smart Apartments', desc:'Individual unit control with central management for property operators.'},
                    {icon:'🏬', title:'Retail Spaces', desc:'Maintain optimal shopping environment while reducing HVAC costs.'},
                  ],
                  'senior-care': [
                    {icon:'🏥', title:'Nursing Homes', desc:'24/7 non-contact monitoring for fall detection, sleep quality, and vital signs.'},
                    {icon:'🏠', title:'Aging in Place', desc:'Enable seniors to live independently with remote family monitoring and alerts.'},
                    {icon:'🏨', title:'Assisted Living', desc:'Staff alerts for emergencies, wander detection, and health trend reports.'},
                    {icon:'📱', title:'Telehealth Integration', desc:'Share health data with doctors for remote consultations and early intervention.'},
                    {icon:'❤️', title:'Memory Care', desc:'Safe zone monitoring and instant alerts for residents with cognitive conditions.'},
                    {icon:'🏘️', title:'Senior Communities', desc:'Community-wide safety net with centralized monitoring dashboard.'},
                  ],
                  'hotel-control': [
                    {icon:'🏨', title:'Boutique Hotels', desc:'Elevate guest experience with smart room controls at an accessible price point.'},
                    {icon:'🏢', title:'Hotel Chains', desc:'Standardize room automation across properties with centralized management.'},
                    {icon:'🏖️', title:'Resorts', desc:'Scene-based controls for lighting, climate, and curtains tied to guest preferences.'},
                    {icon:'💼', title:'Business Hotels', desc:'Energy-saving occupancy detection with seamless guest check-in/out integration.'},
                    {icon:'🛎️', title:'Serviced Apartments', desc:'Long-stay comfort with individual climate control and usage-based billing.'},
                    {icon:'🏛️', title:'Heritage Buildings', desc:'Wireless retrofit without structural changes — preserve architecture, add smarts.'},
                  ],
                  'software-platforms': [
                    {icon:'🏭', title:'Equipment Manufacturers', desc:'White-label your own IoT platform with custom branding and API access.'},
                    {icon:'🏢', title:'Building Operators', desc:'Unified dashboard for energy, HVAC, lighting, and security across portfolios.'},
                    {icon:'🔌', title:'System Integrators', desc:'Open APIs and MQTT bridges to connect OWON hardware with third-party systems.'},
                    {icon:'📊', title:'Energy Consultants', desc:'Data analytics and export for energy audits, ESG reporting, and compliance.'},
                    {icon:'🏗️', title:'Property Developers', desc:'Pre-integrated smart building platform for new construction projects.'},
                    {icon:'🌐', title:'Smart City Projects', desc:'Scalable multi-tenant platform for city-wide IoT device management.'},
                  ],
                };
