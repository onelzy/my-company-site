---
import type { Product } from '~/types';
import { getCollection } from 'astro:content';
import PageLayout from '~/layouts/PageLayout.astro';
import ProductGrid from '~/components/products/ProductGrid.astro';
import ProductFilter from '~/components/products/ProductFilter.astro';

export const prerender = false;

const locale = Astro.currentLocale || 'en';
const allProducts = await getCollection('products');

// Filter by current locale
const products: Product[] = allProducts
  .filter((p) => p.data.language === locale)
  .map((p) => ({
    ...p.data,
    id: p.id,
    slug: p.id.split('/').pop()?.replace('.mdoc', '') || p.data.name.toLowerCase().replace(/\s+/g, '-'),
    collection: 'products' as const,
    data: p.data,
  }));

const title = locale === 'zh' ? '全部产品' : 'All Products';
const description = locale === 'zh'
  ? 'OWON Technology 全系列智能产品——电表、恒温器、智能养老、酒店客控及软件平台'
  : 'OWON Technology complete product range — smart meters, thermostats, senior care, hotel control & software platforms';
---

<PageLayout metadata={{ title, description }}>
  <section class="py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Page Header -->
      <div class="mb-10">
        <h1 class="text-3xl font-bold text-default dark:text-slate-100 sm:text-4xl">
          {title}
        </h1>
        <p class="mt-3 text-lg text-muted dark:text-slate-400 max-w-3xl">
          {description}
        </p>
      </div>

      <div class="lg:grid lg:grid-cols-[280px_1fr] lg:gap-10">
        <!-- Filter Sidebar -->
        <aside class="hidden lg:block">
          <ProductFilter
            filters={{}}
            locale={locale}
            class="sticky top-24"
          />
        </aside>

        <!-- Product Grid -->
        <div>
          <div class="mb-4 text-sm text-muted dark:text-slate-400">
            {products.length} {locale === 'zh' ? '个产品' : 'products'}
          </div>
          <ProductGrid products={products} baseUrl={`/${locale}/products`} />
        </div>
      </div>
    </div>
  </section>
</PageLayout>
