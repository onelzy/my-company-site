---
// products/index.astro — Product catalogue with dual-dimension filtering
// Data from pre-generated src/data/products.ts (build step: scripts/gen-content-data.mjs)
import type { Product } from '~/types';
import PageLayout from '~/layouts/PageLayout.astro';
import ProductCard from '~/components/products/ProductCard.astro';
import {
  PRODUCT_TYPE_LABELS,
  SPEC_LABELS,
  getLocalizedLabel,
  getAllProductTypes,
  getProductSubTypes,
} from '~/utils/products';
import { products as rawProducts } from '~/data/products';

export const prerender = false;

const allProducts = rawProducts.map((entry) => {
  const dataSlug = entry.data?.slug as { name?: string; slug?: string } | undefined;
  const urlSlug = dataSlug?.slug || entry.slug;
  const data = entry.data || {};
  const { slug: _unused, ...restData } = data;
  return { id: entry.slug, slug: urlSlug, collection: 'products' as const, data: entry.data, ...restData };
});

const products: Product[] = allProducts;
const enProducts = products;

const title = 'Product Center';
const description = 'OWON Technology complete product range — smart meters, thermostats, senior care, hotel control & software platforms';

const productTypes = getAllProductTypes();

// Capability classification
const capabilityMeta = {
  intelligence: {
    label: 'Intelligence',
    desc: 'Protocol stacks, cloud platform integration, and data interaction capabilities.',
    chips: [
      { value: 'tuya', label: 'Tuya', group: 'sol' },
      { value: 'mqtt', label: 'MQTT', group: 'sol' },
      { value: 'tcpip', label: 'TCP/IP', group: 'comm' },
      { value: 'modbus', label: 'Modbus', group: 'comm' },
    ],
  },
  connection: {
    label: 'Connection',
    desc: 'Wireless and wired access methods, plus networking and mesh topologies.',
    chips: [
      { value: 'zigbee', label: 'ZigBee', group: 'comm' },
      { value: 'wifi', label: 'WiFi', group: 'comm' },
      { value: '4g', label: '4G', group: 'comm' },
      { value: 'rj45', label: 'RJ45', group: 'comm' },
      { value: 'rf', label: 'RF', group: 'comm' },
      { value: 'rs485', label: 'RS-485', group: 'comm' },
    ],
  },
};

function buildTaxonomy() {
  const typeGroups: Record<string, { label: string; children: Record<string, string> }> = {};
  for (const pt of productTypes) {
    typeGroups[pt] = {
      label: getLocalizedLabel(PRODUCT_TYPE_LABELS, pt, 'en'),
      children: Object.fromEntries(getProductSubTypes(pt).map((s) => [s, getLocalizedLabel(PRODUCT_TYPE_LABELS, s, 'en')])),
    };
  }
  return { typeGroups };
}
---

<PageLayout metadata={{ title, description }}>
  <section class="py-8 lg:py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-8">
        <nav class="mb-4 text-sm text-muted dark:text-slate-400" aria-label="Breadcrumb">
          <a href="/" class="hover:text-primary transition-colors">Home</a>
          <span class="mx-2">/</span>
          <span class="text-default dark:text-slate-200">Products</span>
        </nav>
        <h1 class="text-3xl font-bold text-default dark:text-slate-100 sm:text-4xl">{title}</h1>
      </div>

      <!-- Search -->
      <div class="mb-6">
        <div class="relative max-w-md">
          <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          </span>
          <input type="text" id="productSearch" placeholder="Search products by name, model, or keyword..." class="w-full pl-10 pr-4 py-3 rounded-xl border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-default dark:text-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-shadow" />
        </div>
      </div>

      <!-- Filter: Product Type -->
      <div class="bg-white dark:bg-slate-800/50 rounded-xl p-4 mb-4 border border-gray-200 dark:border-slate-700 shadow-sm" id="filterRow">
        <div class="flex items-center gap-2 flex-wrap">
          <span class="text-xs font-semibold text-gray-700 dark:text-slate-300 uppercase tracking-wider shrink-0">Product Type:</span>
          <button class="filter-chip px-3 py-1.5 rounded-full text-xs font-medium cursor-pointer transition-all duration-150 bg-primary text-primary-foreground border border-primary active" data-group="type" data-value="">All</button>
          {productTypes.map((pt) => (
            <button class="filter-chip px-3 py-1.5 rounded-full text-xs font-medium cursor-pointer transition-all duration-150 text-gray-600 dark:text-slate-400 bg-white dark:bg-slate-800 border border-gray-300 dark:border-slate-600 hover:border-primary dark:hover:border-primary" data-group="type" data-value={pt}>
              {getLocalizedLabel(PRODUCT_TYPE_LABELS, pt, 'en')}
            </button>
          ))}
        </div>
        <div id="typeSubFilters" class="flex items-center gap-2 flex-wrap mt-3 hidden">
          <span class="text-xs font-semibold text-gray-700 dark:text-slate-300 uppercase tracking-wider shrink-0">Sub-Type:</span>
          <button class="filter-chip px-3 py-1.5 rounded-full text-xs font-medium cursor-pointer transition-all duration-150 bg-primary text-primary-foreground border border-primary active" data-group="subtype" data-value="">All</button>
          <div id="subTypeContainer" class="flex items-center gap-2 flex-wrap"></div>
        </div>
      </div>

      <!-- Filter: Capability (Intelligence / Connection) -->
      <div class="bg-white dark:bg-slate-800/50 rounded-xl p-4 mb-6 border border-gray-200 dark:border-slate-700 shadow-sm" id="capFilterRow">
        <!-- Capability tabs -->
        <div class="flex items-center gap-2 flex-wrap mb-3">
          <span class="text-xs font-semibold text-gray-700 dark:text-slate-300 uppercase tracking-wider shrink-0">Capability:</span>
          <button class="cap-tab px-3 py-1.5 rounded-full text-xs font-medium cursor-pointer transition-all duration-150 bg-primary text-primary-foreground active" data-cap="">All</button>
          <button class="cap-tab inline-flex items-center gap-1 px-3 py-1.5 rounded-full text-xs font-medium cursor-pointer transition-all duration-150 text-gray-600 dark:text-slate-400 bg-white dark:bg-slate-800 border border-gray-300 dark:border-slate-600 hover:border-primary dark:hover:border-primary"
            data-cap="intelligence"
            title="Protocol stacks, cloud platform integration, and data interaction capabilities."
          >Intelligence <span class="text-gray-400" title="Protocol stacks, cloud platform integration, and data interaction capabilities.">ⓘ</span></button>
          <button class="cap-tab inline-flex items-center gap-1 px-3 py-1.5 rounded-full text-xs font-medium cursor-pointer transition-all duration-150 text-gray-600 dark:text-slate-400 bg-white dark:bg-slate-800 border border-gray-300 dark:border-slate-600 hover:border-primary dark:hover:border-primary"
            data-cap="connection"
            title="Wireless and wired access methods, plus networking and mesh topologies."
          >Connection <span class="text-gray-400" title="Wireless and wired access methods, plus networking and mesh topologies.">ⓘ</span></button>
        </div>

        <!-- Intelligence chips -->
        <div id="capIntelligence" class="cap-panel hidden">
          <div class="text-xs text-muted dark:text-slate-400 mb-2">Protocol stacks, cloud platform integration, and data interaction capabilities. <span class="text-gray-400">— Tuya, MQTT, TCP/IP, Modbus</span></div>
          <div class="flex items-center gap-2 flex-wrap">
            {capabilityMeta.intelligence.chips.map((chip) => (
              <button class="filter-chip px-3 py-1.5 rounded-full text-xs font-medium cursor-pointer transition-all duration-150 border border-blue-200 dark:border-blue-700 bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-300 hover:bg-blue-100 dark:hover:bg-blue-900/40" data-group={chip.group} data-value={chip.value}>
                {chip.label}
              </button>
            ))}
          </div>
        </div>

        <!-- Connection chips -->
        <div id="capConnection" class="cap-panel hidden">
          <div class="text-xs text-muted dark:text-slate-400 mb-2">Wireless and wired access methods, plus networking and mesh topologies. <span class="text-gray-400">— ZigBee, WiFi, 4G, RJ45, RF, RS-485</span></div>
          <div class="flex items-center gap-2 flex-wrap">
            {capabilityMeta.connection.chips.map((chip) => (
              <button class="filter-chip px-3 py-1.5 rounded-full text-xs font-medium cursor-pointer transition-all duration-150 border border-green-200 dark:border-green-700 bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300 hover:bg-green-100 dark:hover:bg-green-900/40" data-group={chip.group} data-value={chip.value}>
                {chip.label}
              </button>
            ))}
          </div>
        </div>
      </div>

      <div class="flex justify-between items-center mb-6 flex-wrap gap-3" id="resultStats">
        <span class="text-sm text-muted dark:text-slate-400">Showing <strong id="countDisplay" class="text-default dark:text-slate-200 font-semibold">{enProducts.length}</strong> products</span>
      </div>

      <div id="productGrid" class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {enProducts.map((product) => <ProductCard product={product} href="/products" />)}
      </div>

      <div id="emptyState" class="hidden text-center py-16 text-muted dark:text-slate-400">
        <p class="text-lg">No products match your filters</p>
        <p class="text-sm mt-1">Try adjusting your filters</p>
      </div>
    </div>
  </section>
</PageLayout>

<script define:vars={{ taxonomy: buildTaxonomy() }}>
  window.__PRODUCT_TAXONOMY = taxonomy;
</script>

<script>
  // Capability tab switcher
  (function () {
    var tabs = document.querySelectorAll('.cap-tab');
    var panels = document.querySelectorAll('.cap-panel');
    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        var cap = tab.getAttribute('data-cap');
        // Toggle tab styles
        tabs.forEach(function (t) {
          t.classList.remove('bg-primary', 'text-primary-foreground', 'active');
          t.classList.add('text-gray-600', 'dark:text-slate-400', 'bg-white', 'dark:bg-slate-800', 'border', 'border-gray-300', 'dark:border-slate-600');
        });
        tab.classList.remove('text-gray-600', 'dark:text-slate-400', 'bg-white', 'dark:bg-slate-800', 'border', 'border-gray-300', 'dark:border-slate-600');
        tab.classList.add('bg-primary', 'text-primary-foreground', 'active');
        // Show/hide panels
        panels.forEach(function (p) { p.classList.add('hidden'); });
        if (cap === 'intelligence') {
          var p = document.getElementById('capIntelligence');
          if (p) p.classList.remove('hidden');
        } else if (cap === 'connection') {
          var p = document.getElementById('capConnection');
          if (p) p.classList.remove('hidden');
        }
      });
    });
  })();
</script>

<script is:inline src="/scripts/product-filter.js"></script>
