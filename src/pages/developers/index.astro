---
import PageLayout from '~/layouts/PageLayout.astro';
---

<PageLayout metadata={{ title: 'Developers — OWON Technology', description: 'API documentation, SDKs, and integration guides for OWON IoT devices.' }}>
  <section class="py-20">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <h1 class="text-3xl font-bold sm:text-4xl mb-4 text-default dark:text-slate-100">Developer Center</h1>
      <p class="text-lg text-muted dark:text-slate-400 mb-8">
        API documentation, SDKs, and integration guides are coming soon.
      </p>
      <div class="grid gap-6 sm:grid-cols-3 text-left mb-12">
        <div class="p-6 rounded-xl bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700">
          <div class="text-2xl mb-3">📡</div>
          <h3 class="font-semibold mb-1 text-default dark:text-slate-200">REST API</h3>
          <p class="text-sm text-muted dark:text-slate-400">Coming soon — MQTT & HTTP API reference for device management.</p>
        </div>
        <div class="p-6 rounded-xl bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700">
          <div class="text-2xl mb-3">📦</div>
          <h3 class="font-semibold mb-1 text-default dark:text-slate-200">SDKs</h3>
          <p class="text-sm text-muted dark:text-slate-400">Coming soon — Python, Node.js, and Java client libraries.</p>
        </div>
        <div class="p-6 rounded-xl bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700">
          <div class="text-2xl mb-3">📖</div>
          <h3 class="font-semibold mb-1 text-default dark:text-slate-200">Guides</h3>
          <p class="text-sm text-muted dark:text-slate-400">Coming soon — integration tutorials and best practices.</p>
        </div>
      </div>
      <p class="text-sm text-muted dark:text-slate-500">
        For immediate technical support, <a href="/contact" class="text-primary hover:underline">contact our engineering team</a>.
      </p>
    </div>
  </section>
</PageLayout>
