---
import PageLayout from '~/layouts/PageLayout.astro';

const meterClusters = [
  { cluster: '0x0000', name: 'Basic', desc: 'Device info, manufacturer, model, ZCL version' },
  { cluster: '0x0006', name: 'On/Off', desc: 'Relay control (on devices with relay output)' },
  { cluster: '0x0702', name: 'Smart Energy Metering', desc: 'Energy readings: current, voltage, power, total energy' },
  {
    cluster: '0x0B04',
    name: 'Electrical Measurement',
    desc: 'RMS voltage, current, active/reactive power, power factor',
  },
  { cluster: '0x0402', name: 'Temperature Measurement', desc: 'Internal temperature sensor reading' },
  { cluster: '0x0019', name: 'OTA Upgrade', desc: 'Over-the-air firmware update support' },
];

const thermostatClusters = [
  { cluster: '0x0000', name: 'Basic', desc: 'Device info, manufacturer, model, ZCL version' },
  { cluster: '0x0201', name: 'Thermostat', desc: 'Setpoint, mode (heat/cool/auto), temperature display, schedule' },
  { cluster: '0x0402', name: 'Temperature Measurement', desc: 'Local temperature sensor, external probe support' },
  { cluster: '0x0405', name: 'Relative Humidity', desc: 'Humidity sensor (PCT513 with humidity add-on)' },
  { cluster: '0x0006', name: 'On/Off', desc: 'HVAC relay output control' },
  { cluster: '0x0019', name: 'OTA Upgrade', desc: 'Over-the-air firmware update support' },
];

const sleepMonitorClusters = [
  { cluster: '0x0000', name: 'Basic', desc: 'Device info, manufacturer, model, ZCL version' },
  { cluster: '0x0402', name: 'Temperature Measurement', desc: 'Bed/room temperature' },
  { cluster: '0x0400', name: 'Illuminance Measurement', desc: 'Ambient light level' },
  { cluster: '0x0406', name: 'Occupancy Sensing', desc: 'Bed occupancy detection (in/out of bed)' },
  { cluster: '0x0019', name: 'OTA Upgrade', desc: 'Over-the-air firmware update support' },
];
---

<PageLayout
  metadata={{
    title: 'ZigBee Clusters — OWON Developers',
    description: 'ZigBee cluster specifications for OWON smart meters, thermostats, and sleep monitors.',
  }}
>
  <section class="py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex gap-8">
        <!-- Sidebar -->
        <nav class="hidden lg:block w-56 shrink-0 sticky top-24 self-start space-y-1">
          <p class="text-xs font-semibold uppercase text-muted mb-3 tracking-wider">Developers</p>
          <a
            href="/developers"
            class="block px-3 py-2 rounded-lg text-sm text-muted hover:bg-gray-100 dark:hover:bg-slate-800 hover:text-default transition-colors"
            >Overview</a
          >
          <a
            href="/developers/mqtt"
            class="block px-3 py-2 rounded-lg text-sm text-muted hover:bg-gray-100 dark:hover:bg-slate-800 hover:text-default transition-colors"
            >MQTT Quick Start</a
          >
          <a
            href="/developers/api"
            class="block px-3 py-2 rounded-lg text-sm text-muted hover:bg-gray-100 dark:hover:bg-slate-800 hover:text-default transition-colors"
            >HTTP Server API</a
          >
          <a href="/developers/zigbee" class="block px-3 py-2 rounded-lg text-sm font-medium bg-primary/10 text-primary"
            >ZigBee Clusters</a
          >
          <a
            href="/developers/ha"
            class="block px-3 py-2 rounded-lg text-sm text-muted hover:bg-gray-100 dark:hover:bg-slate-800 hover:text-default transition-colors"
            >Home Assistant &amp; Z2M</a
          >
          <a
            href="/developers/sdks"
            class="block px-3 py-2 rounded-lg text-sm text-muted hover:bg-gray-100 dark:hover:bg-slate-800 hover:text-default transition-colors"
            >SDKs &amp; Libraries</a
          >
          <a
            href="/developers/examples"
            class="block px-3 py-2 rounded-lg text-sm text-muted hover:bg-gray-100 dark:hover:bg-slate-800 hover:text-default transition-colors"
            >Code Examples</a
          >
          <a
            href="/developers/changelog"
            class="block px-3 py-2 rounded-lg text-sm text-muted hover:bg-gray-100 dark:hover:bg-slate-800 hover:text-default transition-colors"
            >Firmware Changelog</a
          >
        </nav>

        <!-- Content -->
        <div class="flex-1 min-w-0">
          <!-- Breadcrumb -->
          <nav class="mb-4 text-sm text-muted dark:text-slate-400" aria-label="Breadcrumb">
            <a href="/" class="hover:text-primary transition-colors">Home</a>
            <span class="mx-2">/</span>
            <a href="/developers" class="hover:text-primary transition-colors">Developers</a>
            <span class="mx-2">/</span>
            <span class="text-default dark:text-slate-200">ZigBee Clusters</span>
          </nav>
          <!-- Mobile tabs -->
          <div class="lg:hidden mb-8 -mx-4 px-4 overflow-x-auto scrollbar-none">
            <div class="flex gap-1.5 min-w-max pb-1">
              <a
                href="/developers"
                class="inline-flex shrink-0 px-3.5 py-1.5 rounded-full text-xs font-medium transition-all bg-white dark:bg-slate-800 text-gray-600 dark:text-slate-400 border border-gray-300 dark:border-slate-600 hover:border-primary dark:hover:border-primary no-underline"
                >Overview</a
              >
              <a
                href="/developers/mqtt"
                class="inline-flex shrink-0 px-3.5 py-1.5 rounded-full text-xs font-medium transition-all bg-white dark:bg-slate-800 text-gray-600 dark:text-slate-400 border border-gray-300 dark:border-slate-600 hover:border-primary dark:hover:border-primary no-underline"
                >MQTT Quick Start</a
              >
              <a
                href="/developers/api"
                class="inline-flex shrink-0 px-3.5 py-1.5 rounded-full text-xs font-medium transition-all bg-white dark:bg-slate-800 text-gray-600 dark:text-slate-400 border border-gray-300 dark:border-slate-600 hover:border-primary dark:hover:border-primary no-underline"
                >HTTP Server API</a
              >
              <a
                href="/developers/zigbee"
                class="inline-flex shrink-0 px-3.5 py-1.5 rounded-full text-xs font-semibold transition-all bg-primary text-primary-foreground border border-primary shadow-sm"
                >ZigBee Clusters</a
              >
              <a
                href="/developers/ha"
                class="inline-flex shrink-0 px-3.5 py-1.5 rounded-full text-xs font-medium transition-all bg-white dark:bg-slate-800 text-gray-600 dark:text-slate-400 border border-gray-300 dark:border-slate-600 hover:border-primary dark:hover:border-primary no-underline"
                >HA &amp; Z2M</a
              >
              <a
                href="/developers/sdks"
                class="inline-flex shrink-0 px-3.5 py-1.5 rounded-full text-xs font-medium transition-all bg-white dark:bg-slate-800 text-gray-600 dark:text-slate-400 border border-gray-300 dark:border-slate-600 hover:border-primary dark:hover:border-primary no-underline"
                >SDKs</a
              >
              <a
                href="/developers/examples"
                class="inline-flex shrink-0 px-3.5 py-1.5 rounded-full text-xs font-medium transition-all bg-white dark:bg-slate-800 text-gray-600 dark:text-slate-400 border border-gray-300 dark:border-slate-600 hover:border-primary dark:hover:border-primary no-underline"
                >Examples</a
              >
              <a
                href="/developers/changelog"
                class="inline-flex shrink-0 px-3.5 py-1.5 rounded-full text-xs font-medium transition-all bg-white dark:bg-slate-800 text-gray-600 dark:text-slate-400 border border-gray-300 dark:border-slate-600 hover:border-primary dark:hover:border-primary no-underline"
                >Changelog</a
              >
            </div>
          </div>
          <h1 class="text-3xl font-bold mb-2 text-default dark:text-slate-100">ZigBee Clusters</h1>
          <p class="text-muted dark:text-slate-400 mb-8">
            ZigBee Cluster Library (ZCL) specifications for OWON devices. Use these clusters when integrating with
            custom ZigBee coordinators or Zigbee2MQTT.
          </p>

          <div
            class="mb-8 p-5 rounded-xl bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-700"
          >
            <p class="text-sm text-yellow-800 dark:text-yellow-200">
              <strong>ZigBee 3.0 compliant.</strong> All OWON ZigBee devices follow the ZigBee Cluster Library (ZCL) specification.
              Endpoint and attribute details vary by firmware version — refer to the product datasheet for the exact attribute
              map.
            </p>
          </div>

          <!-- Smart Meter Clusters -->
          <section class="mb-12">
            <h2 class="text-xl font-semibold mb-1 text-default dark:text-slate-200">Smart Energy Meters</h2>
            <p class="text-sm text-muted dark:text-slate-400 mb-4">
              PC321-TY, PC341 series — ZigBee 3.0 Router devices
            </p>
            <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-slate-700">
              <table class="w-full text-sm">
                <thead>
                  <tr class="bg-gray-50 dark:bg-slate-800/50 border-b border-gray-200 dark:border-slate-700">
                    <th class="text-left py-3 px-4 text-muted">Cluster ID</th>
                    <th class="text-left py-3 px-4 text-muted">Name</th>
                    <th class="text-left py-3 px-4 text-muted">Description</th>
                  </tr>
                </thead>
                <tbody class="bg-white dark:bg-slate-800 text-default dark:text-slate-300">
                  {
                    meterClusters.map((c) => (
                      <tr class="border-b border-gray-100 dark:border-slate-700 last:border-b-0">
                        <td class="py-3 px-4 font-mono text-xs text-primary">{c.cluster}</td>
                        <td class="py-3 px-4 font-medium whitespace-nowrap">{c.name}</td>
                        <td class="py-3 px-4 text-muted dark:text-slate-400">{c.desc}</td>
                      </tr>
                    ))
                  }
                </tbody>
              </table>
            </div>
          </section>

          <!-- Thermostat Clusters -->
          <section class="mb-12">
            <h2 class="text-xl font-semibold mb-1 text-default dark:text-slate-200">Smart Thermostats</h2>
            <p class="text-sm text-muted dark:text-slate-400 mb-4">
              PCT513, TRV controllers — ZigBee 3.0 Router devices
            </p>
            <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-slate-700">
              <table class="w-full text-sm">
                <thead>
                  <tr class="bg-gray-50 dark:bg-slate-800/50 border-b border-gray-200 dark:border-slate-700">
                    <th class="text-left py-3 px-4 text-muted">Cluster ID</th>
                    <th class="text-left py-3 px-4 text-muted">Name</th>
                    <th class="text-left py-3 px-4 text-muted">Description</th>
                  </tr>
                </thead>
                <tbody class="bg-white dark:bg-slate-800 text-default dark:text-slate-300">
                  {
                    thermostatClusters.map((c) => (
                      <tr class="border-b border-gray-100 dark:border-slate-700 last:border-b-0">
                        <td class="py-3 px-4 font-mono text-xs text-primary">{c.cluster}</td>
                        <td class="py-3 px-4 font-medium whitespace-nowrap">{c.name}</td>
                        <td class="py-3 px-4 text-muted dark:text-slate-400">{c.desc}</td>
                      </tr>
                    ))
                  }
                </tbody>
              </table>
            </div>
          </section>

          <!-- Sleep Monitor Clusters -->
          <section class="mb-12">
            <h2 class="text-xl font-semibold mb-1 text-default dark:text-slate-200">Sleep Monitors (Senior Care)</h2>
            <p class="text-sm text-muted dark:text-slate-400 mb-4">
              SPM-915 — ZigBee 3.0 End Device (battery optimized)
            </p>
            <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-slate-700">
              <table class="w-full text-sm">
                <thead>
                  <tr class="bg-gray-50 dark:bg-slate-800/50 border-b border-gray-200 dark:border-slate-700">
                    <th class="text-left py-3 px-4 text-muted">Cluster ID</th>
                    <th class="text-left py-3 px-4 text-muted">Name</th>
                    <th class="text-left py-3 px-4 text-muted">Description</th>
                  </tr>
                </thead>
                <tbody class="bg-white dark:bg-slate-800 text-default dark:text-slate-300">
                  {
                    sleepMonitorClusters.map((c) => (
                      <tr class="border-b border-gray-100 dark:border-slate-700 last:border-b-0">
                        <td class="py-3 px-4 font-mono text-xs text-primary">{c.cluster}</td>
                        <td class="py-3 px-4 font-medium whitespace-nowrap">{c.name}</td>
                        <td class="py-3 px-4 text-muted dark:text-slate-400">{c.desc}</td>
                      </tr>
                    ))
                  }
                </tbody>
              </table>
            </div>
          </section>

          <!-- Contact CTA -->
          <div class="rounded-xl bg-primary/5 border border-primary/20 p-6 text-center">
            <p class="text-default dark:text-slate-200 font-medium mb-2">Need custom cluster documentation?</p>
            <p class="text-sm text-muted dark:text-slate-400 mb-4">
              Contact our engineering team for detailed attribute maps, endpoint configurations, and binding
              instructions.
            </p>
            <a
              href="/contact-sales"
              class="inline-flex items-center gap-2 px-6 py-2.5 bg-primary text-white rounded-lg hover:bg-primary/90 transition-colors font-medium text-sm"
            >
              Contact Engineering Team →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
