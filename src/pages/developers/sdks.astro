---
import PageLayout from '~/layouts/PageLayout.astro';

const pythonCode = `from owon_iot import OWONClient

client = OWONClient(api_key="YOUR_API_KEY")

# List devices
devices = client.devices.list()
for d in devices:
    print(f"{d.name}: {d.status}")

# Subscribe to MQTT telemetry
async def on_telemetry(device_id, data):
    print(f"[{device_id}] Power: {data['power']}W")

client.mqtt.subscribe("devices/+/telemetry", on_telemetry)
await client.mqtt.connect()`;

const nodeCode = `import { OWONClient } from '@owon/iot-sdk';

const client = new OWONClient({ apiKey: 'YOUR_API_KEY' });

// List all online devices
const devices = await client.devices.list({ status: 'online' });
console.log(\`Found \${devices.total} online devices\`);

// Subscribe to telemetry
client.mqtt.subscribe('devices/+/telemetry', (deviceId, data) => {
  console.log(\`[\${deviceId}] Power: \${data.power}W\`);
});`;

const javaCode = `import com.owon.iot.OWONClient;
import com.owon.iot.model.Device;

var client = new OWONClient("YOUR_API_KEY");

// List devices
var devices = client.devices().list();
devices.forEach(d -> System.out.println(d.getName()));

// Query telemetry
var telemetry = client.devices().getTelemetry(
    "dev_7a3b9c",
    Instant.now().minus(1, ChronoUnit.HOURS),
    Instant.now()
);`;

const csharpCode = `using Owon.IoT;

var client = new OwonClient("YOUR_API_KEY");

// List devices
var devices = await client.Devices.ListAsync();
foreach (var d in devices.Data)
    Console.WriteLine($"{d.Name}: {d.Status}");

// Query historical telemetry
var telemetry = await client.Devices.GetTelemetryAsync(
    "dev_7a3b9c",
    DateTime.UtcNow.AddHours(-1),
    DateTime.UtcNow
);`;

const mavenDep = `<dependency>
  <groupId>com.owon</groupId>
  <artifactId>owon-iot-sdk</artifactId>
  <version>1.0.2</version>
</dependency>`;
---

<PageLayout
  metadata={{
    title: 'SDKs & Libraries — OWON Developers',
    description: 'Client libraries for integrating with OWON IoT devices — Python, Node.js, Java, C#.',
  }}
>
  <section class="py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex gap-8">
        <nav class="hidden lg:block w-56 shrink-0 sticky top-24 self-start space-y-1">
          <p class="text-xs font-semibold uppercase text-muted mb-3 tracking-wider">Developers</p>
          <a
            href="/developers"
            class="block px-3 py-2 rounded-lg text-sm text-muted hover:bg-gray-100 dark:hover:bg-slate-800 hover:text-default transition-colors"
            >Overview</a
          >
          <a
            href="/developers/api"
            class="block px-3 py-2 rounded-lg text-sm text-muted hover:bg-gray-100 dark:hover:bg-slate-800 hover:text-default transition-colors"
            >API Reference</a
          >
          <a href="/developers/sdks" class="block px-3 py-2 rounded-lg text-sm font-medium bg-primary/10 text-primary"
            >SDKs & Libraries</a
          >
          <a
            href="/developers/examples"
            class="block px-3 py-2 rounded-lg text-sm text-muted hover:bg-gray-100 dark:hover:bg-slate-800 hover:text-default transition-colors"
            >Code Examples</a
          >
          <a
            href="/developers/changelog"
            class="block px-3 py-2 rounded-lg text-sm text-muted hover:bg-gray-100 dark:hover:bg-slate-800 hover:text-default transition-colors"
            >Firmware Changelog</a
          >
        </nav>
        <div class="flex-1 min-w-0">
          <h1 class="text-3xl font-bold mb-2 text-default dark:text-slate-100">SDKs & Libraries</h1>
          <p class="text-muted dark:text-slate-400 mb-8">
            Official client libraries for the OWON IoT Platform. All SDKs support MQTT and REST API access.
          </p>

          <!-- Python -->
          <div class="mb-8 p-6 rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800">
            <div class="flex items-center gap-3 mb-4">
              <span class="text-2xl">🐍</span>
              <h2 class="text-xl font-semibold text-default dark:text-slate-200">Python SDK</h2>
              <span
                class="px-2 py-0.5 rounded text-xs font-medium bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300"
                >v1.3.0</span
              >
            </div>
            <p class="text-sm text-muted dark:text-slate-400 mb-4">
              Full async support with asyncio. MQTT client via paho-mqtt, REST via httpx.
            </p>
            <div class="rounded-lg bg-gray-50 dark:bg-slate-900/50 p-4 font-mono text-sm mb-4">
              <p class="text-muted dark:text-slate-500 mb-1"># Install</p>
              <p class="text-default dark:text-slate-200">pip install owon-iot-sdk</p>
            </div>
            <div class="rounded-lg bg-gray-900 text-gray-100 p-4 font-mono text-xs overflow-x-auto mb-4">
              <pre>{pythonCode}</pre>
            </div>
            <a
              href="https://github.com/onelzy"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-1 text-sm text-primary hover:underline font-medium"
            >
              View on GitHub →
            </a>
          </div>

          <!-- Node.js -->
          <div class="mb-8 p-6 rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800">
            <div class="flex items-center gap-3 mb-4">
              <span class="text-2xl">🟢</span>
              <h2 class="text-xl font-semibold text-default dark:text-slate-200">Node.js SDK</h2>
              <span
                class="px-2 py-0.5 rounded text-xs font-medium bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300"
                >v1.2.1</span
              >
            </div>
            <p class="text-sm text-muted dark:text-slate-400 mb-4">
              TypeScript-first, Promise-based. MQTT via mqtt.js, REST via fetch (native).
            </p>
            <div class="rounded-lg bg-gray-50 dark:bg-slate-900/50 p-4 font-mono text-sm mb-4">
              <p class="text-muted dark:text-slate-500 mb-1"># Install</p>
              <p class="text-default dark:text-slate-200">npm install @owon/iot-sdk</p>
            </div>
            <div class="rounded-lg bg-gray-900 text-gray-100 p-4 font-mono text-xs overflow-x-auto mb-4">
              <pre>{nodeCode}</pre>
            </div>
            <a
              href="https://github.com/onelzy"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-1 text-sm text-primary hover:underline font-medium"
            >
              View on GitHub →
            </a>
          </div>

          <!-- Java -->
          <div class="mb-8 p-6 rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800">
            <div class="flex items-center gap-3 mb-4">
              <span class="text-2xl">☕</span>
              <h2 class="text-xl font-semibold text-default dark:text-slate-200">Java SDK</h2>
              <span
                class="px-2 py-0.5 rounded text-xs font-medium bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300"
                >v1.0.2</span
              >
            </div>
            <p class="text-sm text-muted dark:text-slate-400 mb-4">
              Java 17+. MQTT via Eclipse Paho, REST via OkHttp + Gson.
            </p>
            <div class="rounded-lg bg-gray-50 dark:bg-slate-900/50 p-4 font-mono text-sm mb-4">
              <p class="text-muted dark:text-slate-500 mb-1">&lt;!-- pom.xml --&gt;</p>
              <p class="text-default dark:text-slate-200 whitespace-pre-wrap">{mavenDep}</p>
            </div>
            <div class="rounded-lg bg-gray-900 text-gray-100 p-4 font-mono text-xs overflow-x-auto mb-4">
              <pre>{javaCode}</pre>
            </div>
            <a
              href="https://github.com/onelzy"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-1 text-sm text-primary hover:underline font-medium"
            >
              View on GitHub →
            </a>
          </div>

          <!-- C# -->
          <div class="mb-8 p-6 rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800">
            <div class="flex items-center gap-3 mb-4">
              <span class="text-2xl">🟣</span>
              <h2 class="text-xl font-semibold text-default dark:text-slate-200">C# SDK</h2>
              <span
                class="px-2 py-0.5 rounded text-xs font-medium bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300"
                >v1.0.0</span
              >
            </div>
            <p class="text-sm text-muted dark:text-slate-400 mb-4">
              .NET 8+. MQTT via MQTTnet, REST via HttpClient + System.Text.Json.
            </p>
            <div class="rounded-lg bg-gray-50 dark:bg-slate-900/50 p-4 font-mono text-sm mb-4">
              <p class="text-muted dark:text-slate-500 mb-1"># Install</p>
              <p class="text-default dark:text-slate-200">dotnet add package Owon.IoT.Sdk</p>
            </div>
            <div class="rounded-lg bg-gray-900 text-gray-100 p-4 font-mono text-xs overflow-x-auto mb-4">
              <pre>{csharpCode}</pre>
            </div>
            <a
              href="https://github.com/onelzy"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-1 text-sm text-primary hover:underline font-medium"
            >
              View on GitHub →
            </a>
          </div>

          <!-- GitHub CTA -->
          <div
            class="rounded-xl bg-gray-50 dark:bg-slate-800 border border-gray-200 dark:border-slate-700 p-6 text-center"
          >
            <p class="text-default dark:text-slate-200 font-medium mb-2">All SDKs are open source</p>
            <p class="text-sm text-muted dark:text-slate-400 mb-4">
              Contributions, issues, and feature requests are welcome on GitHub.
            </p>
            <a
              href="https://github.com/onelzy"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 px-6 py-2.5 bg-primary text-white rounded-lg hover:bg-primary/90 transition-colors font-medium text-sm"
            >
              Visit GitHub Organization →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
