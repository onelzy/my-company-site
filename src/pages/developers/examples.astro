---
import PageLayout from '~/layouts/PageLayout.astro';

const mqttPython = `import paho.mqtt.client as mqtt
import json

BROKER = "mqtt.owon-iot.com"
PORT = 8883
USERNAME = "your_project_username"
PASSWORD = "your_project_password"

def on_connect(client, userdata, flags, rc):
    print(f"Connected (rc={rc})")
    # Subscribe to all device telemetry under your project
    client.subscribe("project/+/devices/+/telemetry")

def on_message(client, userdata, msg):
    payload = json.loads(msg.payload)
    topic_parts = msg.topic.split("/")
    device_id = topic_parts[3]
    print(f"[{device_id}] Power: {payload['power']}W | "
          f"Energy: {payload['energy_kwh']}kWh | "
          f"Temp: {payload.get('temperature', 'N/A')}°C")

client = mqtt.Client()
client.username_pw_set(USERNAME, PASSWORD)
client.tls_set()  # TLS required on port 8883
client.on_connect = on_connect
client.on_message = on_message
client.connect(BROKER, PORT)
client.loop_forever()`;

const curlExamples = `BASE="https://api.owon-iot.com/v1"
API_KEY="YOUR_API_KEY"

# 1. List all online smart meters
curl -s -H "Authorization: Bearer $API_KEY" \\
  "$BASE/devices?type=smart-meter&status=online&limit=5" | jq .data[].name

# 2. Get device details + live telemetry
curl -s -H "Authorization: Bearer $API_KEY" \\
  "$BASE/devices/dev_7a3b9c" | jq .

# 3. Query historical energy data (last 24h)
curl -s -H "Authorization: Bearer $API_KEY" \\
  "$BASE/devices/dev_7a3b9c/telemetry?from=$(date -u -d '24 hours ago' +%Y-%m-%dT%H:%M:%SZ)&interval=1h" \\
  | jq .

# 4. Trigger OTA firmware update
curl -s -X POST -H "Authorization: Bearer $API_KEY" \\
  -H "Content-Type: application/json" \\
  -d '{"firmware_version":"2.2.0","firmware_url":"https://firmware.owon-iot.com/v2.2.0.bin"}' \\
  "$BASE/devices/dev_7a3b9c/ota" | jq .`;

const batchOta = `import time
from owon_iot import OWONClient

client = OWONClient(api_key="YOUR_API_KEY")
FIRMWARE_VERSION = "2.2.0"
FIRMWARE_URL = "https://firmware.owon-iot.com/v2.2.0.bin"

def rollout_firmware(device_type: str = "smart-meter"):
    devices = client.devices.list(type=device_type, status="online", limit=100)

    ota_ids = []
    for d in devices.data:
        result = client.devices.trigger_ota(
            d.id,
            firmware_version=FIRMWARE_VERSION,
            firmware_url=FIRMWARE_URL,
        )
        ota_ids.append(result["ota_id"])
        print(f"  Queued {d.name} ({d.id}) -> OTA {result['ota_id']}")

    print(f"\\nRollout started: {len(ota_ids)} devices")
    print("Use GET /ota/{ota_id} to track progress.")

rollout_firmware("smart-meter")`;

const nodeJsDashboard = `import { OWONClient } from '@owon/iot-sdk';

const client = new OWONClient({ apiKey: 'YOUR_API_KEY' });

async function getDashboardSummary() {
  // Get all online devices
  const devices = await client.devices.list({ status: 'online' });

  // Fetch latest telemetry for each device
  const readings = await Promise.all(
    devices.data.map(async (d) => {
      const tel = await client.devices.getTelemetry(
        d.id,
        new Date(Date.now() - 3600_000), // last hour
        new Date()
      );
      return { device: d.name, power: tel.data[tel.data.length - 1]?.power ?? 0 };
    })
  );

  const totalPower = readings.reduce((sum, r) => sum + r.power, 0);
  console.log(\`Online: \${devices.total} devices\`);
  console.log(\`Total power: \${(totalPower / 1000).toFixed(2)} kW\`);
}

getDashboardSummary();`;

const javaAlert = `import com.owon.iot.OWONClient;
import java.time.Duration;
import java.time.Instant;

public class DeviceMonitor {
    private static final Duration OFFLINE_THRESHOLD = Duration.ofMinutes(15);

    public static void main(String[] args) {
        var client = new OWONClient("YOUR_API_KEY");
        var devices = client.devices().list(null, "smart-meter", "all", 100);

        for (var d : devices.getData()) {
            if (d.getStatus().equals("offline")) continue;

            var lastSeen = d.getLastSeen();
            var ago = Duration.between(lastSeen, Instant.now());

            if (ago.compareTo(OFFLINE_THRESHOLD) > 0) {
                System.out.printf(
                    "⚠ ALERT: %s last seen %d min ago%n",
                    d.getName(), ago.toMinutes()
                );
                // Integrate with your alerting system here
                // e.g. sendSlackAlert(d.getName(), ago.toMinutes());
            }
        }
    }
}`;
