---
import PageLayout from '~/layouts/PageLayout.astro';
---

<PageLayout
  metadata={{
    title: 'Code Examples — OWON Developers',
    description: 'Code snippets and integration examples for OWON devices.',
  }}
>
  <section class="py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex gap-8">
        <nav class="hidden lg:block w-56 shrink-0 sticky top-24 self-start space-y-1">
          <p class="text-xs font-semibold uppercase text-muted mb-3 tracking-wider">Developers</p>
          <a
            href="/developers"
            class="block px-3 py-2 rounded-lg text-sm text-muted hover:bg-gray-100 dark:hover:bg-slate-800 hover:text-default transition-colors"
            >Overview</a
          >
          <a
            href="/developers/api"
            class="block px-3 py-2 rounded-lg text-sm text-muted hover:bg-gray-100 dark:hover:bg-slate-800 hover:text-default transition-colors"
            >API Reference</a
          >
          <a
            href="/developers/sdks"
            class="block px-3 py-2 rounded-lg text-sm text-muted hover:bg-gray-100 dark:hover:bg-slate-800 hover:text-default transition-colors"
            >SDKs & Libraries</a
          >
          <a
            href="/developers/examples"
            class="block px-3 py-2 rounded-lg text-sm font-medium bg-primary/10 text-primary">Code Examples</a
          >
          <a
            href="/developers/changelog"
            class="block px-3 py-2 rounded-lg text-sm text-muted hover:bg-gray-100 dark:hover:bg-slate-800 hover:text-default transition-colors"
            >Firmware Changelog</a
          >
        </nav>
        <div class="flex-1 min-w-0">
          <h1 class="text-3xl font-bold mb-6 text-default dark:text-slate-100">Code Examples</h1>
          <p class="text-muted dark:text-slate-400 mb-8">
            Coming soon — practical code snippets for common integration scenarios.
          </p>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
