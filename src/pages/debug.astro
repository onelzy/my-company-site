---
import { getCollection } from 'astro:content';

export const prerender = false;

const products = await getCollection('products');
const solutions = await getCollection('solutions');
---

<h1>Debug: Content Collections</h1>
<h2>Products ({products.length})</h2>
<pre>{JSON.stringify(products.map(p => ({ id: p.id, name: p.data.name, language: p.data.language })), null, 2)}</pre>
<h2>Solutions ({solutions.length})</h2>
<pre>{JSON.stringify(solutions.map(s => ({ id: s.id, title: s.data.title, language: s.data.language })), null, 2)}</pre>
