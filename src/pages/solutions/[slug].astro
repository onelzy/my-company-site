---
// solutions/[slug].astro — Solution detail page
// Data from pre-generated src/data/solutions.ts
import PageLayout from '~/layouts/PageLayout.astro';
import Image from '~/components/common/Image.astro';
import WhatsAppButton from '~/components/common/WhatsAppButton.astro';
import { renderMarkdown } from '~/utils/parseMdoc';
import { solutions as rawSolutions } from '~/data/solutions';
import { products as rawProducts } from '~/data/products';
import { SITE } from 'astrowind:config';
import { PRODUCT_TYPE_LABELS, getLocalizedLabel } from '~/utils/products';

export const prerender = false;

const { slug } = Astro.params;
const entry = rawSolutions.find((s) => s.slug === slug);
if (!entry) return Astro.redirect('/404', 302);

const { title, subtitle, heroImage, diagramImage, stats, productLines, techSolution, industry, caseStudies } = entry.data as Record<
  string,
  unknown
>;
const bodyHtml = renderMarkdown(entry.body || '');

const industryLabels: Record<string, string> = {
  'smart-hotels': 'Smart Hotels',
  'senior-care': 'Senior Care',
  'energy-management': 'Energy Management',
  'smart-building': 'Smart Building',
  'industrial-iot': 'Industrial IoT',
};
const industryLabel = industryLabels[industry || ''] || '';
const techLabels: Record<string, string> = { tuya: 'Tuya', mqtt: 'MQTT', zigbee: 'ZigBee' };
const techLabel = techLabels[techSolution || ''] || '';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${Astro.url.origin}/` },
    { '@type': 'ListItem', position: 2, name: 'Solutions', item: `${Astro.url.origin}/solutions` },
    ...(industryLabel ? ([{ '@type': 'ListItem', position: 3, name: industryLabel }] as const) : []),
    { '@type': 'ListItem', position: industryLabel ? 4 : 3, name: title },
  ],
};

// Cross-reference: find products used in this solution
const solutionProductTypes = (productLines as string[]) || [];
const relatedProducts = rawProducts.filter((p) => {
  const pt = p.data.productType as string | undefined;
  return pt && solutionProductTypes.includes(pt);
});

// Group products by type for display
const productTypeOrder = ['smart-meters', 'thermostats', 'senior-care', 'hotel-control', 'software-platforms'];
const groupedProducts = new Map<string, typeof relatedProducts>();
for (const p of relatedProducts) {
  const pt = (p.data.productType as string) || 'other';
  if (!groupedProducts.has(pt)) groupedProducts.set(pt, []);
  groupedProducts.get(pt)!.push(p);
}
// Sort groups by defined order
const sortedGroups = [...groupedProducts.entries()].sort(
  ([a], [b]) => productTypeOrder.indexOf(a) - productTypeOrder.indexOf(b)
);
---

<PageLayout metadata={{ title: `${title} — OWON Solutions`, description: subtitle || title }}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <section class="py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-8 text-sm text-muted dark:text-slate-400">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span class="mx-2">/</span><a href="/solutions" class="hover:text-primary transition-colors">Solutions</a>
        <span class="mx-2">/</span><span class="text-default dark:text-slate-200 font-medium">{title}</span>
      </nav>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 mb-16">
        <div
          class="relative aspect-video rounded-xl bg-gray-100 dark:bg-slate-800 overflow-hidden border border-gray-200 dark:border-slate-700"
        >
          {
            heroImage ? (
              <Image
                src={heroImage}
                alt={title}
                layout="cover"
                class="absolute inset-0 w-full h-full"
                width={800}
                height={450}
              />
            ) : (
              <div class="absolute inset-0 flex items-center justify-center text-6xl">🏢</div>
            )
          }
        </div>
        <div class="flex flex-col justify-center">
          {
            industryLabel && (
              <span class="text-xs font-bold text-primary uppercase tracking-wider mb-2">{industryLabel}</span>
            )
          }
          <h1 class="text-3xl font-bold sm:text-4xl mb-4 text-default dark:text-slate-100">{title}</h1>
          {subtitle && <p class="text-lg text-muted dark:text-slate-400 mb-6">{subtitle}</p>}
          <div class="flex flex-wrap gap-2 mb-6">
            {
              (productLines || []).map((pl: string) => (
                <span class="px-3 py-1 rounded-full text-xs font-medium bg-primary/10 text-primary border border-primary/20">
                  {pl}
                </span>
              ))
            }
            {
              techLabel && (
                <span class="px-3 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300">
                  {techLabel}
                </span>
              )
            }
          </div>
          <a
            href="/contact-sales"
            class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-primary-foreground rounded-lg font-medium hover:opacity-90 transition-opacity w-fit"
            >Request a Demo →</a
          >
        </div>
      </div>
      {
        stats && stats.length > 0 && (
          <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-16 p-8 bg-gray-50 dark:bg-slate-800/50 rounded-xl border border-gray-200 dark:border-slate-700">
            {stats.map((s: { label?: string; value?: string }) => (
              <div class="text-center">
                <div class="text-3xl font-bold text-primary mb-1">{s.value}</div>
                <div class="text-sm text-muted dark:text-slate-400">{s.label}</div>
              </div>
            ))}
          </div>
        )
      }

      <!-- Key Value Props — like Shelly's 4-up cards -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16">
        {
          [
            {
              icon: '🔌',
              title: 'Plug & Play Integration',
              desc: 'Devices auto-discovered. MQTT, Modbus, ZigBee — connect in minutes, not days.',
            },
            {
              icon: '🔒',
              title: 'Local-First Architecture',
              desc: 'No cloud dependency. All logic runs on-device or on your local network.',
            },
            {
              icon: '📐',
              title: 'Retrofit-Ready',
              desc: 'Wireless installation on existing infrastructure. No rewiring, no downtime.',
            },
            {
              icon: '📊',
              title: 'Open Data Access',
              desc: 'Full REST API, real-time WebSocket streaming, and exportable analytics.',
            },
          ].map((card) => (
            <div class="p-5 rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-center hover:border-primary/30 dark:hover:border-primary/30 hover:shadow-sm transition-all">
              <span class="text-2xl mb-3 block">{card.icon}</span>
              <h4 class="font-semibold text-sm text-default dark:text-slate-200 mb-1.5">{card.title}</h4>
              <p class="text-xs text-muted dark:text-slate-400 leading-relaxed">{card.desc}</p>
            </div>
          ))
        }
      </div>

      {
        diagramImage && (
          <div class="mb-16">
            <>
              <h2 class="text-2xl font-bold mb-6 text-default dark:text-slate-100">System Architecture</h2>
              <div class="rounded-xl border border-gray-200 dark:border-slate-700 overflow-hidden bg-white dark:bg-slate-800 p-4">
                <Image src={diagramImage} alt="System topology" width={1200} height={600} class="w-full h-auto" />
              </div>
            </>
          </div>
        )
      }
      {bodyHtml && <div class="prose prose-lg dark:prose-invert max-w-none" set:html={bodyHtml} />}

      <!-- Related Products — cross-reference -->
      {
        relatedProducts.length > 0 && (
          <section class="mt-16">
            <h2 class="text-2xl font-bold mb-2 text-default dark:text-slate-100">Products Used in This Solution</h2>
            <p class="text-muted dark:text-slate-400 mb-8 text-sm">
              The following OWON products are part of the{' '}
              <strong class="text-default dark:text-slate-200">{title}</strong> solution stack.
            </p>
            {sortedGroups.map(([productType, products]) => (
              <div class="mb-10">
                <h3 class="text-lg font-semibold mb-3 text-default dark:text-slate-200 flex items-center gap-2">
                  <span class="w-2 h-2 rounded-full bg-primary inline-block" />
                  {getLocalizedLabel(PRODUCT_TYPE_LABELS, productType, 'en')}
                </h3>
                <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                  {products.map((p) => {
                    const name = (p.data.name as string) || p.slug;
                    const imageSrc = p.data.image as string | undefined;
                    return (
                      <a
                        href={`/products/${p.slug}`}
                        class="group flex items-center gap-4 p-4 rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 hover:border-primary/30 dark:hover:border-primary/30 hover:shadow-sm transition-all"
                      >
                        <div class="w-14 h-14 rounded-lg bg-gray-100 dark:bg-slate-700 flex items-center justify-center flex-shrink-0 overflow-hidden border border-gray-200 dark:border-slate-600">
                          {imageSrc ? (
                            <Image
                              src={imageSrc}
                              alt={name}
                              width={56}
                              height={56}
                              class="w-full h-full object-contain p-1"
                            />
                          ) : (
                            <span class="text-xl">
                              {p.slug.startsWith('edgeeco')
                                ? '☁️'
                                : p.slug.startsWith('pc')
                                  ? '⚡'
                                  : p.slug.startsWith('pct')
                                    ? '🌡️'
                                    : '🛏️'}
                            </span>
                          )}
                        </div>
                        <div class="min-w-0 flex-1">
                          <h4 class="font-medium text-sm text-default dark:text-slate-200 group-hover:text-primary transition-colors truncate">
                            {name}
                          </h4>
                          <p class="text-xs text-muted dark:text-slate-500 mt-0.5 line-clamp-1">
                            {(p.data.model || '') as string}
                          </p>
                        </div>
                        <svg
                          class="w-4 h-4 text-gray-300 dark:text-slate-600 group-hover:text-primary transition-colors flex-shrink-0"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                      </a>
                    );
                  })}
                </div>
              </div>
            ))}
          </section>
        )
      }

      <!-- Related Case Studies -->
      {
        caseStudies && (caseStudies as Array<any>).length > 0 && (
          <section class="mt-16">
            <h2 class="text-2xl font-bold mb-2 text-default dark:text-slate-100">Related Case Studies</h2>
            <p class="text-muted dark:text-slate-400 mb-8 text-sm">
              Real-world deployments and results from our customers.
            </p>
            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
              {(caseStudies as Array<{ title: string; excerpt: string; image: string; blogSlug: string }>).map((cs) => (
                <a
                  href={`/blog/${cs.blogSlug}/`}
                  class="group block rounded-xl bg-white dark:bg-slate-800 shadow-md hover:shadow-xl border border-gray-200 dark:border-slate-700 transition-all overflow-hidden"
                >
                  <div class="h-40 bg-gray-100 dark:bg-slate-700 overflow-hidden relative">
                    <img
                      src={cs.image}
                      alt={cs.title}
                      class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                    />
                  </div>
                  <div class="p-5">
                    <h3 class="font-semibold text-sm text-default dark:text-slate-200 group-hover:text-primary transition-colors mb-2">
                      {cs.title}
                    </h3>
                    <p class="text-xs text-muted dark:text-slate-400 line-clamp-2">{cs.excerpt}</p>
                    <span class="inline-block mt-3 text-xs font-medium text-primary group-hover:underline">
                      Read full case study →
                    </span>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )
      }

      <!-- Certifications & Trust — Shelly-style trust badges -->
      <div class="mt-16 p-8 bg-gray-50 dark:bg-slate-800/50 rounded-xl border border-gray-200 dark:border-slate-700">
        <h2 class="text-xl font-bold text-default dark:text-slate-100 mb-4 text-center">Trusted Quality</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl mx-auto">
          {
            [
              { icon: '✅', title: 'CE Certified', desc: 'Meets EU safety, health, and environmental requirements.' },
              {
                icon: '✅',
                title: 'FCC Certified',
                desc: 'Compliant with US Federal Communications Commission standards.',
              },
              {
                icon: '♻️',
                title: 'RoHS Compliant',
                desc: 'Free of hazardous substances — environmentally responsible.',
              },
              {
                icon: '🛡️',
                title: '2–5 Year Warranty',
                desc: 'Industry-leading warranty with global technical support.',
              },
            ].map((badge) => (
              <div class="flex items-start gap-3 p-3">
                <span class="text-lg shrink-0 mt-0.5">{badge.icon}</span>
                <div>
                  <h5 class="font-semibold text-xs text-default dark:text-slate-200">{badge.title}</h5>
                  <p class="text-xs text-muted dark:text-slate-400 mt-0.5">{badge.desc}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <div class="mt-16 text-center p-12 bg-primary/5 dark:bg-primary/10 rounded-2xl border border-primary/10">
        <h2 class="text-2xl font-bold mb-3 text-default dark:text-slate-100">Interested in this solution?</h2>
        <p class="text-muted dark:text-slate-400 mb-6">
          Get a personalized demo, pricing, or download the full case study.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <button
            class="px-6 py-3 bg-primary text-primary-foreground rounded-lg font-semibold hover:opacity-90 transition-opacity"
            onclick={`window.__openLeadModal({ scenario: 'price', productName: '${title}' })`}
          >
            Request Pricing
          </button>
          <button
            class="px-6 py-3 border border-primary text-primary rounded-lg font-semibold hover:bg-primary/5 transition-colors"
            onclick={`window.__openLeadModal({ scenario: 'case', productName: '${title}' })`}
          >
            Download Case Study
          </button>
          <a
            href="/contact-sales"
            class="px-6 py-3 bg-primary text-primary-foreground rounded-lg font-semibold hover:opacity-90 transition-opacity"
          >
            Contact Sales →
          </a>
        </div>
      </div>
    </div>
  </section>
  <WhatsAppButton
    phone={(SITE as unknown as Record<string, Record<string, string>>).contact?.whatsapp || '8618650139895'}
    productName={String(title)}
    company={(SITE as unknown as Record<string, Record<string, string>>).contact?.company || 'OWON Technology'}
    pageUrl={`/solutions/${slug}`}
    siteUrl="https://www.owon-iot.com"
  />
</PageLayout>
