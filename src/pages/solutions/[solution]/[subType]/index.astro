---
import type { GetStaticPaths } from 'astro';
import type { Product, TechSolution } from '~/types';
import { getCollection } from 'astro:content';
import PageLayout from '~/layouts/PageLayout.astro';
import ProductGrid from '~/components/products/ProductGrid.astro';
import ProductFilter from '~/components/products/ProductFilter.astro';
import {
  TECH_SOLUTION_LABELS,
  getLocalizedLabel,
  getAllTechSolutions,
  getTechSubTypes,
} from '~/utils/products';

export const prerender = true;

export const getStaticPaths: GetStaticPaths = () => {
  const locales = ['en', 'zh', 'es', 'ru', 'fr', 'de', 'ar', 'pt'];
  const solutions = getAllTechSolutions();
  const paths: { params: { solution: string; subType: string }; props: { locale: string } }[] = [];

  for (const locale of locales) {
    for (const solution of solutions) {
      const subTypes = getTechSubTypes(solution);
      for (const subType of subTypes) {
        paths.push({
          params: { solution, subType },
          props: { locale },
        });
      }
    }
  }
  return paths;
};

const { solution, subType } = Astro.params;
const { locale } = Astro.props as { locale: string };

const allProducts = await getCollection('products');

const products: Product[] = allProducts
  .filter(
    (p) =>
      p.data.language === locale &&
      p.data.techSolution === solution &&
      p.data.techSubType === subType
  )
  .map((p) => ({
    ...p.data,
    id: p.id,
    slug: p.id.split('/').pop()?.replace('.mdoc', '') || p.data.name.toLowerCase().replace(/\s+/g, '-'),
    collection: 'products' as const,
    data: p.data,
  }));

const solutionLabel = getLocalizedLabel(TECH_SOLUTION_LABELS, solution, locale);
const subTypeLabel = getLocalizedLabel(TECH_SOLUTION_LABELS, subType, locale);
const title = `${subTypeLabel} — ${solutionLabel} | OWON Technology`;
const description =
  locale === 'zh'
    ? `${subTypeLabel}系列产品（${solutionLabel}技术方案），OWON Technology 提供专业的${subTypeLabel}解决方案`
    : `${subTypeLabel} products (${solutionLabel} solution) — OWON Technology professional ${subTypeLabel} solutions`;
---

<PageLayout metadata={{ title, description }}>
  <section class="py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="mb-6 text-sm text-muted dark:text-slate-400">
        <a href={`/${locale}/solutions`} class="hover:text-primary transition-colors">
          {locale === 'zh' ? '技术方案' : 'Solutions'}
        </a>
        <span class="mx-2" aria-hidden="true">/</span>
        <a href={`/${locale}/solutions/${solution}`} class="hover:text-primary transition-colors">
          {solutionLabel}
        </a>
        <span class="mx-2" aria-hidden="true">/</span>
        <span class="text-default dark:text-slate-200 font-medium">{subTypeLabel}</span>
      </nav>

      <!-- Page Header -->
      <div class="mb-10">
        <h1 class="text-3xl font-bold text-default dark:text-slate-100 sm:text-4xl">
          {subTypeLabel}
        </h1>
        <p class="mt-2 text-lg text-muted dark:text-slate-400">
          <span class="inline-flex items-center gap-1.5">
            <span class="px-3 py-1 rounded-full bg-primary/10 text-primary dark:bg-primary/20 dark:text-primary-foreground text-sm font-medium">
              {solutionLabel}
            </span>
            <span>
              {products.length} {locale === 'zh' ? '个产品' : 'products'}
            </span>
          </span>
        </p>
      </div>

      <div class="lg:grid lg:grid-cols-[280px_1fr] lg:gap-10">
        <!-- Filter Sidebar -->
        <aside class="hidden lg:block">
          <ProductFilter
            filters={{
              techSolution: solution as TechSolution,
              techSubType: subType,
            }}
            locale={locale}
            class="sticky top-24"
          />
        </aside>

        <!-- Product Grid -->
        <ProductGrid products={products} baseUrl={`/${locale}/solutions`} />
      </div>
    </div>
  </section>
</PageLayout>
