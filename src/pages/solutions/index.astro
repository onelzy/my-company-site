---
// solutions/index.astro — Industry solution listing
// Data from pre-generated src/data/solutions.ts
import PageLayout from '~/layouts/PageLayout.astro';
import Image from '~/components/common/Image.astro';
import { solutions as rawSolutions } from '~/data/solutions';

export const prerender = false;

// English MVP — all content is English, skip language filter
const solutions = rawSolutions;

const industries = [
  { value: 'smart-hotels', label: 'Smart Hotels' },
  { value: 'senior-care', label: 'Senior Care' },
  { value: 'energy-management', label: 'Energy Management' },
  { value: 'smart-building', label: 'Smart Building' },
  { value: 'industrial-iot', label: 'Industrial IoT' },
];
const industryIcons: Record<string, string> = {
  'smart-hotels': '🏨',
  'senior-care': '🏥',
  'energy-management': '⚡',
  'smart-building': '🏢',
  'industrial-iot': '🏭',
};
function getIndustryLabel(value: string): string {
  return industries.find((i) => i.value === value)?.label || '';
}

const preparedSolutions = solutions.map((s) => {
  const d = s.data as Record<string, string | number>;
  return {
    slug: s.slug,
    title: d.title as string | undefined,
    subtitle: d.subtitle as string | undefined,
    heroImage: d.heroImage as string | undefined,
    industry: d.industry as string | undefined,
    indLabel: getIndustryLabel((d.industry as string) || ''),
    icon: industryIcons[(d.industry as string) || ''] || '🏢',
  };
});
---

<PageLayout metadata={{ title: 'Use Cases — OWON Technology', description: 'Industry-specific IoT use cases.' }}>
  <section class="py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl font-bold sm:text-4xl mb-6 text-default dark:text-slate-100">Use Cases</h1>

      <!-- Search -->
      <div class="mb-6">
        <div class="relative max-w-md">
          <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg
            >
          </span>
          <input
            type="text"
            id="solutionSearch"
            placeholder="Search use cases by industry, keyword..."
            class="w-full pl-10 pr-4 py-3 rounded-xl border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-default dark:text-slate-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-shadow"
          />
        </div>
      </div>

      <!-- Count -->
      <span class="text-sm text-muted dark:text-slate-400 mb-4 block">
        Showing <strong id="solutionCount" class="text-default dark:text-slate-200 font-semibold"
          >{preparedSolutions.length}</strong
        > use cases
      </span>

      <!-- Filters -->
      <div class="flex items-center gap-2 flex-wrap mb-6" id="industryFilters">
        <span class="text-xs font-semibold text-gray-700 dark:text-slate-300 uppercase tracking-wider shrink-0"
          >Industry:</span
        >
        <button
          class="filter-chip px-3 py-1.5 rounded-full text-xs font-medium cursor-pointer transition-all bg-primary text-primary-foreground border border-primary active"
          data-industry="">All</button
        >
        {
          industries.map((ind) => (
            <button
              class="filter-chip px-3 py-1.5 rounded-full text-xs font-medium cursor-pointer transition-all bg-white dark:bg-slate-800 text-gray-600 dark:text-slate-400 border border-gray-300 dark:border-slate-600 hover:border-primary dark:hover:border-primary"
              data-industry={ind.value}
            >
              {ind.label}
            </button>
          ))
        }
      </div>

      <div id="solGrid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          preparedSolutions.map((s) => (
            <a
              href={`/solutions/${s.slug}`}
              class="solution-card group block rounded-xl bg-white dark:bg-slate-800 shadow-md hover:shadow-xl border border-gray-200 dark:border-slate-700 transition-all overflow-hidden"
              data-industry={s.industry || ''}
            >
              <div class="h-48 bg-gray-100 dark:bg-slate-700 overflow-hidden relative flex items-center justify-center text-5xl">
                {s.heroImage ? (
                  <Image
                    src={s.heroImage}
                    alt={s.title || ''}
                    layout="cover"
                    class="absolute inset-0 w-full h-full"
                    width={600}
                    height={400}
                  />
                ) : (
                  <span>{s.icon}</span>
                )}
              </div>
              <div class="p-5">
                {s.indLabel && (
                  <span class="text-xs font-semibold text-primary uppercase tracking-wide">{s.indLabel}</span>
                )}
                <h3 class="text-lg font-semibold mt-1 mb-2 text-default dark:text-slate-200 group-hover:text-primary transition-colors">
                  {s.title}
                </h3>
                {s.subtitle && <p class="text-sm text-muted dark:text-slate-400 line-clamp-2">{s.subtitle}</p>}
              </div>
            </a>
          ))
        }
        {
          solutions.length === 0 && (
            <div class="col-span-full text-center py-16 text-muted dark:text-slate-400">
              <>
                <p class="text-lg">No solutions yet.</p>
                <a href="/keystatic" class="text-primary hover:underline text-sm mt-2 inline-block">
                  Open CMS →
                </a>
              </>
            </div>
          )
        }
      </div>
    </div>
  </section>
</PageLayout>

<script is:inline src="/scripts/solution-filter.js"></script>
