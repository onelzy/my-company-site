---
// Parse optional solution and sub-type from URL, redirect to products page with query params
const path = Astro.params.path || '';
const parts = path.split('/').filter(Boolean);
const solution = parts[0] || '';
const subType = parts[1] || '';

const params = new URLSearchParams();
if (solution) params.set('sol', solution);
if (subType) params.set('techsub', subType);

const query = params.toString();
const redirectUrl = `/products/${query ? '?' + query : ''}`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content={"0;url=" + redirectUrl} />
    <script is:inline>window.location.href={JSON.stringify(redirectUrl)};</script>
  </head>
  <body>
    <p>Redirecting to <a href={redirectUrl}>products</a>...</p>
  </body>
</html>
