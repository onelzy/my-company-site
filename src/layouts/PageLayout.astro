---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/widgets/Header.astro';
import Footer from '~/components/widgets/Footer.astro';
import Announcement from '~/components/widgets/Announcement.astro';

import { headerData, footerData } from '~/navigation';

import type { MetaData } from '~/types';

interface AlternateLink {
  hreflang: string;
  href: string;
}

export interface Props {
  metadata?: MetaData;
  alternates?: AlternateLink[];
}

const { metadata, alternates } = Astro.props;

// -------------------------------------------------------------------
// Locale-aware navigation: prefix all internal hrefs with the current
// locale so links like /products become /zh/products when appropriate.
// -------------------------------------------------------------------
const locale = Astro.currentLocale || 'en';

function localizeHref(obj: any): any {
  if (Array.isArray(obj)) return obj.map(localizeHref);
  if (obj && typeof obj === 'object') {
    const result: any = {};
    for (const [key, val] of Object.entries(obj)) {
      if (key === 'href' && typeof val === 'string' && val.startsWith('/') && !val.startsWith('//')) {
        result[key] = locale === 'en' ? val : `/${locale}${val}`;
      } else {
        result[key] = localizeHref(val);
      }
    }
    return result;
  }
  return obj;
}

const localizedHeader = localizeHref(headerData);
const localizedFooter = localizeHref(footerData);
---

<Layout metadata={metadata} alternates={alternates}>
  <slot name="announcement">
    <Announcement />
  </slot>
  <slot name="header">
    <Header {...localizedHeader} isSticky showRssFeed showToggleTheme showLanguagePicker />
  </slot>
  <main>
    <slot />
  </main>
  <slot name="footer">
    <Footer {...localizedFooter} />
  </slot>
</Layout>
