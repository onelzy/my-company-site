---
import PageLayout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';

import { headerData } from '~/navigation';
import type { MetaData } from '~/types';

export interface Props {
  metadata?: MetaData;
}

const { metadata } = Astro.props;

// Locale-aware href prefixing
const locale = Astro.currentLocale || 'en';
function localizeHref(obj: any): any {
  if (Array.isArray(obj)) return obj.map(localizeHref);
  if (obj && typeof obj === 'object') {
    const result: any = {};
    for (const [key, val] of Object.entries(obj)) {
      if (key === 'href' && typeof val === 'string' && val.startsWith('/') && !val.startsWith('//')) {
        result[key] = locale === 'en' ? val : `/${locale}${val}`;
      } else {
        result[key] = localizeHref(val);
      }
    }
    return result;
  }
  return obj;
}

const companyLinks = headerData?.links[2] ? [headerData.links[2]] : undefined;
const localizedLinks = localizeHref(companyLinks);
---

<PageLayout metadata={metadata}>
  <Fragment slot="announcement">
    <slot name="announcement" />
  </Fragment>
  <Fragment slot="header">
    <slot name="header">
      <Header
        links={localizedLinks}
        actions={[
          {
            text: 'Download',
            href: 'https://github.com/arthelokyo/astrowind',
          },
        ]}
        showToggleTheme
        showLanguagePicker
        position="right"
      />
    </slot>
  </Fragment>
  <slot />
</PageLayout>
