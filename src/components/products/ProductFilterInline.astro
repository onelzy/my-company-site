---
/**
 * ProductFilterInline.astro — Mobile-friendly horizontal filter bar.
 *
 * Shown on small screens (hidden on lg+ where the sidebar is visible).
 * Renders a horizontal scrollable row of quick-filter toggle buttons plus a
 * "Filters" button that opens the full filter sidebar in a right-sliding
 * drawer overlay.
 *
 * Props:
 *   filters: ProductFilterState — selected filter values
 *   locale:  string             — locale code for labels
 */
import { twMerge } from 'tailwind-merge';
import type { ProductFilterState } from '~/types';
import {
  PRODUCT_TYPE_LABELS,
  TECH_SOLUTION_LABELS,
  SPEC_LABELS,
  getLocalizedLabel,
  getAllProductTypes,
  getProductSubTypes,
} from '~/utils/products';

export interface Props {
  filters: ProductFilterState;
  locale: string;
  class?: string;
}

const { filters, locale, class: className } = Astro.props;

// ===================================================================
// Same trees used in ProductFilter.astro
// ===================================================================
const techSolutionTree: Record<string, string[]> = {
  tuya: ['tuya-meters', 'tuya-thermostats', 'tuya-lighting', 'tuya-gateways', 'tuya-remotes', 'tuya-senior', 'tuya-sensors'],
  mqtt: ['mqtt-meters', 'mqtt-thermostats', 'mqtt-gateways', 'mqtt-remotes', 'mqtt-software'],
  zigbee: ['zigbee-meters', 'zigbee-thermostats', 'zigbee-lighting', 'zigbee-gateways', 'zigbee-remotes', 'zigbee-senior', 'zigbee-sensors', 'zigbee-energy', 'zigbee-software'],
};

const productTypes = getAllProductTypes();
const techSolutions = Object.keys(techSolutionTree);
const communicationKeys = ['zigbee', 'wifi', '4g', 'lora', 'nb-iot', 'modbus', 'mqtt', 'tcpip', 'rj45'];
const ecosystemKeys = ['tuya', 'mqtt-open', 'zigbee-solution', 'home-assistant', 'local-api'];

const isSelected = (value: string | undefined, key: string): boolean => value === key;

const hasAnyFilter =
  !!filters.productType ||
  !!filters.productSubType ||
  !!filters.techSolution ||
  !!filters.techSubType ||
  (filters.communication && filters.communication.length > 0) ||
  (filters.ecosystem && filters.ecosystem.length > 0) ||
  (filters.extraTags && filters.extraTags.length > 0) ||
  (filters.softwareType && filters.softwareType.length > 0);

/** Build a list of active filter labels for the quick-filter row. */
interface QuickFilter { key: string; label: string; active: boolean }
const quickFilters: QuickFilter[] = [
  ...productTypes.map((pt) => ({
    key: `type:${pt}`,
    label: getLocalizedLabel(PRODUCT_TYPE_LABELS, pt, locale),
    active: isSelected(filters.productType, pt),
  })),
  ...techSolutions.map((ts) => ({
    key: `sol:${ts}`,
    label: getLocalizedLabel(TECH_SOLUTION_LABELS, ts, locale),
    active: isSelected(filters.techSolution, ts),
  })),
  ...communicationKeys.map((c) => ({
    key: `comm:${c}`,
    label: getLocalizedLabel(SPEC_LABELS, c, locale),
    active: (filters.communication || []).includes(c),
  })),
  ...ecosystemKeys.map((e) => ({
    key: `eco:${e}`,
    label: getLocalizedLabel(SPEC_LABELS, e, locale),
    active: (filters.ecosystem || []).includes(e),
  })),
];

const activeCount = quickFilters.filter((f) => f.active).length;
---

<div
  class={twMerge(
    'product-filter-inline lg:hidden',
    'flex items-center gap-2 w-full overflow-x-auto pb-2',
    className
  )}
>
  <!-- Quick-filter toggle buttons (horizontal scroll) -->
  <div class="flex items-center gap-2 flex-nowrap">
    {quickFilters.map((qf) => (
      <button
        type="button"
        class={twMerge(
          'inline-flex items-center gap-1 px-3 py-1.5 rounded-full text-xs font-medium whitespace-nowrap',
          'border transition-colors duration-150 cursor-pointer flex-shrink-0',
          qf.active
            ? 'bg-primary text-primary-foreground border-primary'
            : 'bg-white dark:bg-slate-800 text-muted dark:text-slate-400 border-gray-300 dark:border-slate-600 hover:border-primary dark:hover:border-primary'
        )}
        data-quick-filter={qf.key}
      >
        {qf.label}
        {qf.active && (
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
          </svg>
        )}
      </button>
    ))}
  </div>

  <!-- Filters button → opens drawer -->
  <button
    type="button"
    id="mobile-filters-btn"
    class={twMerge(
      'inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium whitespace-nowrap flex-shrink-0 cursor-pointer',
      'border transition-colors duration-150',
      hasAnyFilter
        ? 'bg-primary text-primary-foreground border-primary'
        : 'bg-white dark:bg-slate-800 text-muted dark:text-slate-400 border-gray-300 dark:border-slate-600 hover:border-primary dark:hover:border-primary'
    )}
    aria-haspopup="dialog"
  >
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
    </svg>
    Filters
    {activeCount > 0 && (
      <span class="inline-flex items-center justify-center w-4 h-4 rounded-full bg-white text-primary text-[10px] font-bold">
        {activeCount}
      </span>
    )}
  </button>
</div>

<!-- ================================================================= -->
<!-- Mobile Filter Drawer (dialog overlay)                              -->
<!-- ================================================================= -->
<dialog
  id="filter-drawer"
  class="product-filter fixed inset-y-0 right-0 m-0 mr-0 w-full max-w-sm h-full max-h-full
         bg-white dark:bg-slate-900 shadow-2xl
         backdrop:bg-black/50 backdrop:backdrop-blur-sm
         p-0 border-0
         translate-x-full open:translate-x-0
         transition-transform duration-300 ease-in-out"
  aria-label="Filter drawer"
>
  <div class="flex flex-col h-full">
    <!-- Drawer header -->
    <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200 dark:border-slate-700">
      <h2 class="text-lg font-bold text-default dark:text-slate-200">Filters</h2>
      <button
        type="button"
        id="filter-drawer-close"
        class="inline-flex items-center justify-center w-8 h-8 rounded-lg
               text-muted dark:text-slate-400 hover:bg-gray-100 dark:hover:bg-slate-800
               transition-colors cursor-pointer"
        aria-label="Close filters"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Drawer body — full filter sidebar content -->
    <div class="flex-1 overflow-y-auto px-5 py-4">
      <div class="mb-4">
        {
          hasAnyFilter && (
            <button
              type="button"
              id="drawer-clear-btn"
              class="text-xs text-primary hover:text-primary/80 dark:text-primary dark:hover:text-primary/80
                     font-medium underline underline-offset-2 transition-colors cursor-pointer"
            >
              Clear All Filters
            </button>
          )
        }
      </div>

      <!-- =========================================================== -->
      <!-- Product Type Tree                                           -->
      <!-- =========================================================== -->
      <fieldset class="mb-6">
        <legend class="w-full mb-2 text-sm font-semibold text-default dark:text-slate-200 uppercase tracking-wider">
          Product Type
        </legend>
        <div class="space-y-1">
          {productTypes.map((parent) => (
            <div>
              <label class="flex items-center gap-2 px-2 py-1.5 rounded-md cursor-pointer select-none text-sm text-muted dark:text-slate-400 hover:bg-gray-100 dark:hover:bg-slate-700/50 transition-colors duration-150">
                <input
                  type="checkbox"
                  class="filter-checkbox sr-only peer"
                  data-filter-group="type"
                  data-filter-value={parent}
                  checked={isSelected(filters.productType, parent)}
                />
                <span class="relative flex items-center justify-center w-4 h-4 rounded border flex-shrink-0
                             border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-800
                             peer-checked:bg-primary peer-checked:border-primary
                             transition-colors duration-150">
                  <svg class="w-3 h-3 text-white hidden peer-checked:block" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </span>
                <span class="truncate">{getLocalizedLabel(PRODUCT_TYPE_LABELS, parent, locale)}</span>
              </label>
              <div class="ml-4 border-l border-gray-200 dark:border-slate-700 pl-3 filter-subgroup">
                {getProductSubTypes(parent).map((child: string) => (
                  <label class="flex items-center gap-2 px-2 py-1.5 rounded-md cursor-pointer select-none text-sm text-muted dark:text-slate-400 hover:bg-gray-100 dark:hover:bg-slate-700/50 transition-colors duration-150">
                    <input
                      type="checkbox"
                      class="filter-checkbox sr-only peer"
                      data-filter-group="subtype"
                      data-filter-value={child}
                      data-filter-parent={parent}
                      checked={isSelected(filters.productSubType, child)}
                    />
                    <span class="relative flex items-center justify-center w-4 h-4 rounded border flex-shrink-0
                                 border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-800
                                 peer-checked:bg-primary peer-checked:border-primary
                                 transition-colors duration-150">
                      <svg class="w-3 h-3 text-white hidden peer-checked:block" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                      </svg>
                    </span>
                    <span class="truncate">{getLocalizedLabel(PRODUCT_TYPE_LABELS, child, locale)}</span>
                  </label>
                ))}
              </div>
            </div>
          ))}
        </div>
      </fieldset>

      <!-- =========================================================== -->
      <!-- Tech Solution Tree                                          -->
      <!-- =========================================================== -->
      <fieldset class="mb-6">
        <legend class="w-full mb-2 text-sm font-semibold text-default dark:text-slate-200 uppercase tracking-wider">
          Tech Solution
        </legend>
        <div class="space-y-1">
          {techSolutions.map((parent) => (
            <div>
              <label class="flex items-center gap-2 px-2 py-1.5 rounded-md cursor-pointer select-none text-sm text-muted dark:text-slate-400 hover:bg-gray-100 dark:hover:bg-slate-700/50 transition-colors duration-150">
                <input
                  type="checkbox"
                  class="filter-checkbox sr-only peer"
                  data-filter-group="sol"
                  data-filter-value={parent}
                  checked={isSelected(filters.techSolution, parent)}
                />
                <span class="relative flex items-center justify-center w-4 h-4 rounded border flex-shrink-0
                             border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-800
                             peer-checked:bg-primary peer-checked:border-primary
                             transition-colors duration-150">
                  <svg class="w-3 h-3 text-white hidden peer-checked:block" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </span>
                <span class="truncate">{getLocalizedLabel(TECH_SOLUTION_LABELS, parent, locale)}</span>
              </label>
              <div class="ml-4 border-l border-gray-200 dark:border-slate-700 pl-3 filter-subgroup">
                {techSolutionTree[parent]!.map((child: string) => (
                  <label class="flex items-center gap-2 px-2 py-1.5 rounded-md cursor-pointer select-none text-sm text-muted dark:text-slate-400 hover:bg-gray-100 dark:hover:bg-slate-700/50 transition-colors duration-150">
                    <input
                      type="checkbox"
                      class="filter-checkbox sr-only peer"
                      data-filter-group="subsol"
                      data-filter-value={child}
                      data-filter-parent={parent}
                      checked={isSelected(filters.techSubType, child)}
                    />
                    <span class="relative flex items-center justify-center w-4 h-4 rounded border flex-shrink-0
                                 border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-800
                                 peer-checked:bg-primary peer-checked:border-primary
                                 transition-colors duration-150">
                      <svg class="w-3 h-3 text-white hidden peer-checked:block" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                      </svg>
                    </span>
                    <span class="truncate">{getLocalizedLabel(TECH_SOLUTION_LABELS, child, locale)}</span>
                  </label>
                ))}
              </div>
            </div>
          ))}
        </div>
      </fieldset>

      <!-- =========================================================== -->
      <!-- Communication Methods                                       -->
      <!-- =========================================================== -->
      <fieldset class="mb-6">
        <legend class="w-full mb-2 text-sm font-semibold text-default dark:text-slate-200 uppercase tracking-wider">
          Communication
        </legend>
        <div class="space-y-1">
          {communicationKeys.map((method) => (
            <label class="flex items-center gap-2 px-2 py-1.5 rounded-md cursor-pointer select-none text-sm text-muted dark:text-slate-400 hover:bg-gray-100 dark:hover:bg-slate-700/50 transition-colors duration-150">
              <input
                type="checkbox"
                class="filter-checkbox sr-only peer"
                data-filter-group="comm"
                data-filter-value={method}
                checked={(filters.communication || []).includes(method)}
              />
              <span class="relative flex items-center justify-center w-4 h-4 rounded border flex-shrink-0
                           border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-800
                           peer-checked:bg-primary peer-checked:border-primary
                           transition-colors duration-150">
                <svg class="w-3 h-3 text-white hidden peer-checked:block" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </span>
              <span class="truncate">{getLocalizedLabel(SPEC_LABELS, method, locale)}</span>
            </label>
          ))}
        </div>
      </fieldset>

      <!-- =========================================================== -->
      <!-- Ecosystems                                                  -->
      <!-- =========================================================== -->
      <fieldset class="mb-6">
        <legend class="w-full mb-2 text-sm font-semibold text-default dark:text-slate-200 uppercase tracking-wider">
          Ecosystem
        </legend>
        <div class="space-y-1">
          {ecosystemKeys.map((eco) => (
            <label class="flex items-center gap-2 px-2 py-1.5 rounded-md cursor-pointer select-none text-sm text-muted dark:text-slate-400 hover:bg-gray-100 dark:hover:bg-slate-700/50 transition-colors duration-150">
              <input
                type="checkbox"
                class="filter-checkbox sr-only peer"
                data-filter-group="eco"
                data-filter-value={eco}
                checked={(filters.ecosystem || []).includes(eco)}
              />
              <span class="relative flex items-center justify-center w-4 h-4 rounded border flex-shrink-0
                           border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-800
                           peer-checked:bg-primary peer-checked:border-primary
                           transition-colors duration-150">
                <svg class="w-3 h-3 text-white hidden peer-checked:block" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </span>
              <span class="truncate">{getLocalizedLabel(SPEC_LABELS, eco, locale)}</span>
            </label>
          ))}
        </div>
      </fieldset>
    </div>

    <!-- Drawer footer — Apply button -->
    <div class="px-5 py-4 border-t border-gray-200 dark:border-slate-700">
      <button
        type="button"
        id="filter-drawer-apply"
        class="w-full inline-flex items-center justify-center px-4 py-2.5 rounded-lg
               bg-primary text-primary-foreground font-medium text-sm
               hover:bg-primary/90 transition-colors cursor-pointer"
      >
        Apply Filters
      </button>
    </div>
  </div>
</dialog>

<!-- Filter JS — served from public/ directory -->
<script src="/scripts/product-filter.js"></script>

<!-- Mobile drawer & quick-filter plumbing -->
<script>
  (function () {
    const drawer = document.getElementById('filter-drawer');
    const openBtn = document.getElementById('mobile-filters-btn');
    const closeBtn = document.getElementById('filter-drawer-close');
    const applyBtn = document.getElementById('filter-drawer-apply');
    const clearBtn = document.getElementById('drawer-clear-btn');
    const clearSidebarBtn = document.getElementById('clear-filters-btn');

    if (!drawer) return;

    function openDrawer() { drawer.showModal(); }
    function closeDrawer() { drawer.close(); }

    openBtn?.addEventListener('click', openDrawer);
    closeBtn?.addEventListener('click', closeDrawer);
    applyBtn?.addEventListener('click', closeDrawer);

    // Clear-all buttons (both sidebar and drawer)
    function clearAll() {
      if (window.ProductFilter) {
        window.ProductFilter.reset();
      }
    }
    clearBtn?.addEventListener('click', clearAll);
    clearSidebarBtn?.addEventListener('click', clearAll);

    // Close drawer when clicking the backdrop
    drawer.addEventListener('click', function (e) {
      if (e.target === drawer) closeDrawer();
    });

    // Quick-filter toggle buttons: clicking one checks the corresponding
    // sidebar/drawer checkbox and triggers the filter update.
    document.querySelectorAll('[data-quick-filter]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        const key = btn.getAttribute('data-quick-filter'); // e.g. "type:smart-meters"
        if (!key) return;
        const [group, value] = key.split(':');
        // Find the matching checkbox in the sidebar or drawer
        const checkbox = document.querySelector(
          `.filter-checkbox[data-filter-group="${group}"][data-filter-value="${value}"]`
        );
        if (checkbox) {
          checkbox.checked = !checkbox.checked;
          checkbox.dispatchEvent(new Event('change', { bubbles: true }));
        }
      });
    });
  })();
</script>
