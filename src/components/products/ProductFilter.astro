---
/**
 * ProductFilter.astro — Filter sidebar (static display placeholder).
 *
 * Props:
 *   filters: ProductFilterState — selected filter values
 *   locale:  string             — locale code for labels
 *
 * Phase 6 will add full interactivity. For now, all filters render
 * as a static visual structure showing the available options.
 */
import { twMerge } from 'tailwind-merge';
import type { ProductFilterState } from '~/types';
import {
  PRODUCT_TYPE_LABELS,
  TECH_SOLUTION_LABELS,
  SPEC_LABELS,
  getLocalizedLabel,
  getAllProductTypes,
  getProductSubTypes,
} from '~/utils/products';

export interface Props {
  filters: ProductFilterState;
  locale: string;
  class?: string;
}

const { filters, locale, class: className } = Astro.props;

// ===================================================================
// Tech Solution tree: parent → children
// ===================================================================
const techSolutionTree: Record<string, string[]> = {
  tuya: ['tuya-meters', 'tuya-thermostats', 'tuya-lighting', 'tuya-gateways', 'tuya-remotes', 'tuya-senior', 'tuya-sensors'],
  mqtt: ['mqtt-meters', 'mqtt-thermostats', 'mqtt-gateways', 'mqtt-remotes', 'mqtt-software'],
  zigbee: ['zigbee-meters', 'zigbee-thermostats', 'zigbee-lighting', 'zigbee-gateways', 'zigbee-remotes', 'zigbee-senior', 'zigbee-sensors', 'zigbee-energy', 'zigbee-software'],
};

// Helpers
const isSelected = (list: readonly string[], key: string): boolean =>
  list.includes(key);

// Flat product types list
const productTypes = getAllProductTypes();
const techSolutions = Object.keys(techSolutionTree);

// Communication methods (from SPEC_LABELS)
const communicationKeys = ['zigbee', 'wifi', '4g', 'lora', 'nb-iot', 'modbus', 'mqtt', 'tcpip', 'rj45'];

// Ecosystem keys (from SPEC_LABELS)
const ecosystemKeys = ['tuya', 'mqtt-open', 'zigbee-solution', 'home-assistant', 'local-api'];
---

<aside
  class={twMerge(
    'w-full lg:w-64 xl:w-72 flex-shrink-0',
    'bg-white dark:bg-slate-800/50 rounded-xl p-5',
    'border border-gray-200 dark:border-slate-700',
    className
  )}
>
  <h2 class="text-lg font-bold text-default dark:text-slate-200 mb-4">
    Filters
  </h2>

  <!-- =============================================================== -->
  <!-- Product Type Tree                                               -->
  <!-- =============================================================== -->
  <fieldset class="mb-6">
    <legend class="w-full mb-2 text-sm font-semibold text-default dark:text-slate-200 uppercase tracking-wider">
      Product Type
    </legend>
    <div class="space-y-1">
      {productTypes.map((parent) => (
        <div>
          <label class="flex items-center gap-2 px-2 py-1.5 rounded-md cursor-default select-none text-sm text-muted dark:text-slate-400">
            <span class="relative flex items-center justify-center w-4 h-4 rounded border flex-shrink-0 border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-800 transition-colors duration-150">
              {isSelected(filters.productTypes, parent) && (
                <svg class="w-3 h-3 text-primary" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              )}
            </span>
            <span class="truncate">{getLocalizedLabel(PRODUCT_TYPE_LABELS, parent, locale)}</span>
          </label>
          <div class="ml-4 border-l border-gray-200 dark:border-slate-700 pl-3">
            {getProductSubTypes(parent).map((child: string) => (
              <label class="flex items-center gap-2 px-2 py-1.5 rounded-md cursor-default select-none text-sm text-muted dark:text-slate-400">
                <span class="relative flex items-center justify-center w-4 h-4 rounded border flex-shrink-0 border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-800 transition-colors duration-150">
                  {/* unchecked — no interactivity yet */}
                </span>
                <span class="truncate">{getLocalizedLabel(PRODUCT_TYPE_LABELS, child, locale)}</span>
              </label>
            ))}
          </div>
        </div>
      ))}
    </div>
  </fieldset>

  <!-- =============================================================== -->
  <!-- Tech Solution Tree                                               -->
  <!-- =============================================================== -->
  <fieldset class="mb-6">
    <legend class="w-full mb-2 text-sm font-semibold text-default dark:text-slate-200 uppercase tracking-wider">
      Tech Solution
    </legend>
    <div class="space-y-1">
      {techSolutions.map((parent) => (
        <div>
          <label class="flex items-center gap-2 px-2 py-1.5 rounded-md cursor-default select-none text-sm text-muted dark:text-slate-400">
            <span class="relative flex items-center justify-center w-4 h-4 rounded border flex-shrink-0 border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-800 transition-colors duration-150">
              {isSelected(filters.techSolutions, parent) && (
                <svg class="w-3 h-3 text-primary" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              )}
            </span>
            <span class="truncate">{getLocalizedLabel(TECH_SOLUTION_LABELS, parent, locale)}</span>
          </label>
          <div class="ml-4 border-l border-gray-200 dark:border-slate-700 pl-3">
            {techSolutionTree[parent]!.map((child: string) => (
              <label class="flex items-center gap-2 px-2 py-1.5 rounded-md cursor-default select-none text-sm text-muted dark:text-slate-400">
                <span class="relative flex items-center justify-center w-4 h-4 rounded border flex-shrink-0 border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-800 transition-colors duration-150">
                  {/* unchecked — no interactivity yet */}
                </span>
                <span class="truncate">{getLocalizedLabel(TECH_SOLUTION_LABELS, child, locale)}</span>
              </label>
            ))}
          </div>
        </div>
      ))}
    </div>
  </fieldset>

  <!-- =============================================================== -->
  <!-- Communication Methods (checkboxes)                               -->
  <!-- =============================================================== -->
  <fieldset class="mb-6">
    <legend class="w-full mb-2 text-sm font-semibold text-default dark:text-slate-200 uppercase tracking-wider">
      Communication
    </legend>
    <div class="space-y-1">
      {communicationKeys.map((method) => (
        <label class="flex items-center gap-2 px-2 py-1.5 rounded-md cursor-default select-none text-sm text-muted dark:text-slate-400">
          <span class="relative flex items-center justify-center w-4 h-4 rounded border flex-shrink-0 border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-800 transition-colors duration-150">
            {isSelected(filters.communication, method) && (
              <svg class="w-3 h-3 text-primary" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            )}
          </span>
          <span class="truncate">{getLocalizedLabel(SPEC_LABELS, method, locale)}</span>
        </label>
      ))}
    </div>
  </fieldset>

  <!-- =============================================================== -->
  <!-- Ecosystems (checkboxes)                                          -->
  <!-- =============================================================== -->
  <fieldset class="mb-6">
    <legend class="w-full mb-2 text-sm font-semibold text-default dark:text-slate-200 uppercase tracking-wider">
      Ecosystem
    </legend>
    <div class="space-y-1">
      {ecosystemKeys.map((eco) => (
        <label class="flex items-center gap-2 px-2 py-1.5 rounded-md cursor-default select-none text-sm text-muted dark:text-slate-400">
          <span class="relative flex items-center justify-center w-4 h-4 rounded border flex-shrink-0 border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-800 transition-colors duration-150">
            {isSelected(filters.ecosystems, eco) && (
              <svg class="w-3 h-3 text-primary" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            )}
          </span>
          <span class="truncate">{getLocalizedLabel(SPEC_LABELS, eco, locale)}</span>
        </label>
      ))}
    </div>
  </fieldset>
</aside>
