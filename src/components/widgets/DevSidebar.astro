---
export interface Props {
  currentPage: 'overview' | 'mqtt' | 'api' | 'zigbee' | 'ha' | 'sdks' | 'examples' | 'changelog';
}

const { currentPage } = Astro.props;

interface SidebarItem {
  slug: string;
  label: string;
  href: string;
}

interface SidebarGroup {
  label: string;
  children: SidebarItem[];
}

const groups: SidebarGroup[] = [
  {
    label: 'Getting Started',
    children: [
      { slug: 'overview', label: 'Overview', href: '/developers' },
      { slug: 'mqtt', label: 'MQTT Quick Start', href: '/developers/mqtt' },
    ],
  },
  {
    label: 'API Reference',
    children: [
      { slug: 'api', label: 'HTTP Server API', href: '/developers/api' },
      { slug: 'zigbee', label: 'ZigBee Clusters', href: '/developers/zigbee' },
    ],
  },
  {
    label: 'Integration',
    children: [
      { slug: 'ha', label: 'Home Assistant & Z2M', href: '/developers/ha' },
      { slug: 'sdks', label: 'SDKs & Libraries', href: '/developers/sdks' },
    ],
  },
  {
    label: 'Resources',
    children: [
      { slug: 'examples', label: 'Code Examples', href: '/developers/examples' },
      { slug: 'changelog', label: 'Firmware Changelog', href: '/developers/changelog' },
    ],
  },
];
---

<nav class="hidden lg:block w-56 shrink-0 sticky top-24 self-start">
  <p class="text-xs font-semibold uppercase text-muted mb-3 tracking-wider">Developers</p>
  <div class="space-y-4">
    {
      groups.map((group) => (
        <div class="dev-sidebar-group">
          <button
            class="flex items-center gap-1.5 w-full text-left text-xs font-semibold uppercase text-muted tracking-wider mb-1 px-1 py-1 rounded hover:text-default transition-colors"
            data-toggle-group
            aria-expanded="true"
          >
            <svg
              class="w-3 h-3 transition-transform duration-200"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polyline points="6 9 12 15 18 9" />
            </svg>
            {group.label}
          </button>
          <div class="space-y-0.5">
            {group.children.map((child) => {
              const isActive = currentPage === child.slug;
              return (
                <a
                  href={child.href}
                  class:list={[
                    'block px-3 py-1.5 text-sm transition-colors border-l-2',
                    isActive
                      ? 'bg-primary/10 border-primary text-primary font-medium'
                      : 'text-muted hover:bg-gray-100 dark:hover:bg-slate-800 hover:text-default border-transparent',
                  ]}
                >
                  {child.label}
                </a>
              );
            })}
          </div>
        </div>
      ))
    }
  </div>
</nav>

<script>
  document.querySelectorAll('[data-toggle-group]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const content = btn.nextElementSibling;
      const chevron = btn.querySelector('svg');
      const isHidden = content.classList.toggle('hidden');
      chevron.style.transform = isHidden ? 'rotate(-90deg)' : 'rotate(0deg)';
      btn.setAttribute('aria-expanded', !isHidden);
    });
  });

  function addCopyButtons() {
    document.querySelectorAll('.bg-gray-900').forEach((block) => {
      if (block.querySelector('.copy-btn')) return;
      const pre = block.querySelector('pre');
      if (!pre) return;
      block.classList.add('relative');
      const btn = document.createElement('button');
      btn.className =
        'copy-btn absolute top-2 right-2 px-2 py-1 text-xs bg-gray-700 hover:bg-gray-600 text-gray-300 rounded transition-colors';
      btn.textContent = 'Copy';
      btn.onclick = () => {
        navigator.clipboard.writeText(pre.textContent);
        btn.textContent = 'Copied!';
        setTimeout(() => {
          btn.textContent = 'Copy';
        }, 2000);
      };
      block.appendChild(btn);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', addCopyButtons);
  } else {
    addCopyButtons();
  }
</script>
