---
/**
 * CommonMeta — shared <head> metadata for all pages.
 *
 * Currently English-only. hreflang alternates are reserved for
 * future multi-language expansion — uncomment the block and
 * re-enable i18n in astro.config.ts when ready.
 */
import { getAsset } from '~/utils/permalinks';

// const LOCALES = ['en', 'zh', 'es', 'ru', 'fr', 'de', 'ar', 'pt'] as const;

interface AlternateLink {
  hreflang: string;
  href: string;
}

interface Props {
  alternates?: AlternateLink[];
}

const { alternates } = Astro.props as Props;

const links: AlternateLink[] = alternates || [];
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<link rel="sitemap" href={getAsset('/sitemap-index.xml')} />

{links.length > 0 && links.map((link) => <link rel="alternate" hreflang={link.hreflang} href={link.href} />)}
