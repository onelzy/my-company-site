---
// LeadCaptureModal.astro — B2B lead capture overlay (3 scenarios)
---

<div
  id="lead-modal"
  class="fixed inset-0 z-[9999] hidden items-end sm:items-center justify-center"
  role="dialog"
  aria-modal="true"
  aria-labelledby="lead-modal-title"
>
  <!-- Backdrop -->
  <div id="lead-modal-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm transition-opacity"></div>

  <!-- Modal card -->
  <div
    class="relative w-full sm:max-w-md bg-white dark:bg-slate-900 rounded-t-2xl sm:rounded-2xl shadow-2xl p-6 sm:p-8 mx-0 sm:mx-4 animate-slide-up"
  >
    <!-- Close button -->
    <button
      id="lead-modal-close"
      class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 transition-colors"
      aria-label="Close"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>

    <!-- Icon -->
    <div id="lead-modal-icon" class="w-12 h-12 rounded-xl flex items-center justify-center mb-4"></div>

    <!-- Title -->
    <h3 id="lead-modal-title" class="text-xl font-bold text-default dark:text-slate-100 mb-2"></h3>

    <!-- Subtitle -->
    <p id="lead-modal-subtitle" class="text-sm text-muted dark:text-slate-400 mb-6"></p>

    <!-- Form -->
    <form id="lead-modal-form" class="space-y-4">
      <div>
        <label for="lead-email" class="block text-sm font-medium text-default dark:text-slate-200 mb-1">
          Business Email <span class="text-red-500">*</span>
        </label>
        <input
          type="email"
          id="lead-email"
          required
          placeholder="you@company.com"
          class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-default dark:text-slate-100 placeholder:text-gray-400 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition text-sm"
        />
        <p id="lead-email-error" class="hidden text-xs text-red-500 mt-1">Please use a business email address</p>
      </div>
      <div id="lead-company-group" class="hidden">
        <label for="lead-company" class="block text-sm font-medium text-default dark:text-slate-200 mb-1">
          Company Name
        </label>
        <input
          type="text"
          id="lead-company"
          placeholder="Your company"
          class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-default dark:text-slate-100 placeholder:text-gray-400 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition text-sm"
        />
      </div>
      <button
        type="submit"
        id="lead-modal-submit"
        class="w-full py-3 px-6 bg-primary text-primary-foreground rounded-lg font-semibold hover:opacity-90 transition-opacity"
      ></button>
    </form>

    <!-- Success state -->
    <div id="lead-modal-success" class="hidden text-center py-6">
      <div
        class="w-16 h-16 bg-green-100 dark:bg-green-900/30 rounded-full flex items-center justify-center mx-auto mb-4"
      >
        <svg class="w-8 h-8 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
      </div>
      <h3 class="text-lg font-bold text-default dark:text-slate-100 mb-1">Thank You!</h3>
      <p id="lead-modal-success-msg" class="text-sm text-muted dark:text-slate-400"></p>
    </div>
  </div>
</div>

<style is:global>
  @keyframes slide-up {
    from {
      transform: translateY(100%);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }
  .animate-slide-up {
    animation: slide-up 0.3s ease-out;
  }
  @media (min-width: 640px) {
    @keyframes slide-up {
      from {
        transform: translateY(20px);
        opacity: 0;
      }
      to {
        transform: translateY(0);
        opacity: 1;
      }
    }
  }
</style>
